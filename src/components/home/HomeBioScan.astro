---
const portraitSrc = '/assets/tejas-khandale-portrait.jpg';

const identity = {
  name: ['TEJAS', 'KHANDALE'],
  role: 'FULL-STACK ENGINEER • AI SYSTEMS BUILDER',
  intro: 'I build production AI systems, automation tools and scalable web platforms that solve real problems.'
};

const actions = [
  { label: 'VIEW PROJECTS', href: '/projects/', icon: 'play', route: 'projects' },
  { label: 'DOWNLOAD RESUME', href: '/assets/Tejas%20Khandale%20(1).pdf', icon: 'doc', download: 'Tejas-Khandale-Resume.pdf' }
];
---

<section class="bio-scan" aria-labelledby="bio-scan-title">
  <svg class="bio-connectors" viewBox="0 0 1060 420" preserveAspectRatio="none" aria-hidden="true">
    <path class="bio-connector bio-connector--identity" pathLength="1" d="M382 94 H424 V334" />
    <path class="bio-connector bio-connector--focus" pathLength="1" d="M424 154 H462" />
    <path class="bio-connector bio-connector--contact" pathLength="1" d="M424 304 H462" />
  </svg>

  <div class="bio-portrait-module" aria-label="Operator portrait scan">
    <span class="stats-opener bio-opener" aria-hidden="true"></span>
    <span class="stats-corner stats-corner--tl bio-corner" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--tr bio-corner" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--bl bio-corner" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--br bio-corner" aria-hidden="true"><i></i></span>

    <div class="bio-portrait-frame">
      <img class="bio-portrait" src={portraitSrc} alt="Portrait of Tejas Khandale" loading="eager" decoding="async" />
      <span class="bio-portrait-noise" aria-hidden="true"></span>
      <span class="bio-portrait-scan" aria-hidden="true"></span>
    </div>
  </div>

  <div class="bio-copy" style="--bio-card-delay: 760ms">
    <span class="stats-opener bio-opener" aria-hidden="true"></span>
    <span class="bio-copy-line" aria-hidden="true"></span>
    <h1 id="bio-scan-title" class="bio-title">
        {identity.name.map((line) => <span>{line}</span>)}
    </h1>
    <p class="bio-role">{identity.role}</p>
    <p class="bio-intro">{identity.intro}</p>

    <div class="bio-actions" aria-label="Primary actions">
      {actions.map((action, index) => (
        <a
          class={`bio-card bio-card--cta bio-card--cta-${action.icon}`}
          style={`--bio-card-delay: ${1160 + index * 180}ms`}
          href={action.href}
          data-home-cta={action.icon}
          data-home-route={action.route}
          data-home-download={action.download ? 'true' : undefined}
          download={action.download}
        >
          <span class="stats-opener bio-opener" aria-hidden="true"></span>
          <span class="stats-corner stats-corner--tl bio-corner" aria-hidden="true"><i></i></span>
          <span class="stats-corner stats-corner--tr bio-corner" aria-hidden="true"><i></i></span>
          <span class="stats-corner stats-corner--bl bio-corner" aria-hidden="true"><i></i></span>
          <span class="stats-corner stats-corner--br bio-corner" aria-hidden="true"><i></i></span>
          <span class="bio-card-divider bio-card-divider--short" aria-hidden="true"></span>
          <span class="bio-card-content bio-contact-content">
            <span class={`bio-cta-icon bio-cta-icon--${action.icon}`} aria-hidden="true"></span>
            <span class="bio-label">{action.label}</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

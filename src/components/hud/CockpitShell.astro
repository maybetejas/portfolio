---
import HologramViewport from './HologramViewport.astro';
import ScrollDepthMeter from './ScrollDepthMeter.astro';
import SystemStats from './SystemStats.astro';
import VisionModeSwitch from './VisionModeSwitch.astro';

const navItems = [
  {
    href: '/',
    section: 'home',
    label: 'HOME',
    radarX: 36,
    radarY: 60,
    icon: '<path d="M5.5 14.5 12 7.5l6.5 7" /><path d="M8.25 13.75V20h7.5v-6.25" />'
  },
  {
    href: '/about/',
    section: 'about',
    label: 'ABOUT',
    radarX: 45,
    radarY: 38,
    icon: '<path d="M12 4.5c2.4 2.5 4.2 5.2 4.2 8.1 0 2.7-1.6 4.8-4.2 6.9-2.6-2.1-4.2-4.2-4.2-6.9 0-2.9 1.8-5.6 4.2-8.1Z" /><path d="M12 13.5v6" />'
  },
  {
    href: '/projects/',
    section: 'projects',
    label: 'PROJECTS',
    radarX: 50,
    radarY: 50,
    icon: '<path d="M6 15.5C6 9 12 4.5 12 4.5S18 9 18 15.5" /><path d="M9 16c.75-2.7 3-4.5 3-4.5s2.25 1.8 3 4.5" /><path d="M12 16.5V21" />'
  },
  {
    href: '/blog/',
    section: 'lab',
    label: 'LAB',
    radarX: 62,
    radarY: 40,
    icon: '<path d="M12 4.5v15" /><path d="M8 8.5c2.2 1.2 3.2 3.1 4 5.6" /><path d="M16 8.5c-2.2 1.2-3.2 3.1-4 5.6" /><path d="M8.5 16.5h7" />'
  },
  {
    href: '/contact/',
    section: 'contact',
    label: 'CONTACT',
    radarX: 68,
    radarY: 62,
    icon: '<path d="M12 4.5v15" /><path d="M8 9.5c1.8 1 3.1 2.2 4 4.6" /><path d="M16 9.5c-1.8 1-3.1 2.2-4 4.6" /><path d="M6.5 17.5c2.8-.4 4.3-1.2 5.5-3.4" /><path d="M17.5 17.5c-2.8-.4-4.3-1.2-5.5-3.4" />'
  }
];

const normalizePath = (path: string) => {
  if (path === '/') return path;
  return path.endsWith('/') ? path : `${path}/`;
};

const currentPath = normalizePath(Astro.url.pathname);
const isActiveNavItem = (href: string) => href === '/' ? currentPath === href : currentPath.startsWith(href);
const activeNavItem = navItems.find((item) => isActiveNavItem(item.href)) ?? navItems[2];
const centerNavIndex = Math.floor(navItems.length / 2);
const activeNavIndex = Math.max(navItems.findIndex((item) => item.section === activeNavItem.section), 0);
---

<div class="cockpit-shell" data-cockpit-shell data-current-section={activeNavItem.section} data-vision-mode="visible" data-phase="jump">
  <div class="space-background" aria-hidden="true"></div>
  <div class="warp-intro" aria-hidden="true">
    <canvas class="hyperspace-canvas" data-hyperspace-canvas></canvas>
  </div>
  <div class="glass-overlay" aria-hidden="true"></div>

  <div class="hud-stage" aria-hidden="true">
    <div class="hud-projection" data-hud-projection>
      <picture class="hud-frame" aria-hidden="true">
        <source media="(max-width: 760px)" srcset="/assets/frameMobile.png" />
        <img src="/assets/framePC.png" alt="" loading="eager" decoding="async" />
      </picture>
    </div>
  </div>

  <div class="nav-system" data-nav-system>
    <SystemStats />
    <VisionModeSwitch />
    <ScrollDepthMeter />

    <nav class="xeno-navbar hud-boot-item" aria-label="Primary navigation" data-xeno-navbar data-boot-order="5">
      {
        navItems.map((item, index) => (
          <a
            href={item.href}
            class={`xeno-nav-button${index === activeNavIndex ? ' is-active' : ''}`}
            data-xeno-nav-button
            data-section={item.section}
            data-route={item.href}
            data-depth={Math.min(Math.abs(index - centerNavIndex), 2)}
            aria-current={isActiveNavItem(item.href) ? 'page' : undefined}
            style={`--button-index: ${index}; --boot-distance: ${Math.abs(index - centerNavIndex)};`}
          >
            <svg class="xeno-veins" viewBox="0 0 100 56" preserveAspectRatio="none" aria-hidden="true">
              <path class="vein vein-a" d="M50 30 C42 25 39 17 30 14 C21 11 18 8 12 4" />
              <path class="vein vein-b" d="M50 29 C40 32 34 38 25 37 C18 36 14 42 7 47" />
              <path class="vein vein-c" d="M50 29 C58 24 62 16 70 14 C79 12 84 7 91 5" />
              <path class="vein vein-d" d="M50 31 C61 34 66 41 76 39 C84 38 88 43 95 49" />
              <path class="vein vein-e" d="M50 29 C45 20 49 15 43 9 C39 5 35 4 31 2" />
              <path class="vein vein-f" d="M51 29 C56 21 53 14 59 9 C63 5 68 5 73 2" />
              <path class="vein vein-g" d="M49 31 C42 35 43 43 36 47 C31 50 27 50 21 54" />
              <path class="vein vein-h" d="M51 31 C58 36 57 44 64 48 C70 51 75 50 82 54" />
            </svg>

            <span class="xeno-core">
              <svg
                class="xeno-icon"
                viewBox="0 0 24 24"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <Fragment set:html={item.icon} />
              </svg>
              <span class="xeno-label">{item.label}</span>
            </span>
          </a>
        ))
      }
    </nav>

    <div class="portfolio-radar hud-boot-item" data-boot-order="3" aria-label={`Portfolio location radar. Current location: ${activeNavItem.label}.`} role="img">
      <div class="radar-plane" aria-hidden="true">
        <span class="radar-ring radar-ring--outer"></span>
        <span class="radar-ring radar-ring--inner radar-ring--one"></span>
        <span class="radar-ring radar-ring--inner radar-ring--two"></span>
        <span class="radar-ring radar-ring--inner radar-ring--three"></span>
        <span class="radar-axis radar-axis--vertical"></span>
        <span class="radar-axis radar-axis--horizontal"></span>
        <span class="radar-sweep"></span>
        {
          navItems.map((item) => (
            <span
              class="radar-dot"
              data-radar-label={item.label}
              data-radar-section={item.section}
              data-active={isActiveNavItem(item.href) ? 'true' : undefined}
              style={`--radar-x: ${item.radarX}%; --radar-y: ${item.radarY}%;`}
            />
          ))
        }
      </div>
    </div>
  </div>

  <main class="content-viewport" data-content-viewport tabindex="-1">
    <HologramViewport />
    <div class="page-slot" hidden>
      <slot />
    </div>
  </main>
</div>

<script>
  const shell = document.querySelector<HTMLElement>('[data-cockpit-shell]');
  const viewport = document.querySelector<HTMLElement>('[data-content-viewport]');
  const xenoNavButtons = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-xeno-nav-button]'));
  const sectionPanels = Array.from(document.querySelectorAll<HTMLElement>('[data-section-panel]'));
  const radarDots = Array.from(document.querySelectorAll<HTMLElement>('[data-radar-section]'));
  const visionOptions = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-vision-option]'));
  const scrollDepth = document.querySelector<HTMLElement>('[data-scroll-depth]');
  const scrollPercent = document.querySelector<HTMLOutputElement>('[data-scroll-percent]');
  const warpIntro = document.querySelector<HTMLElement>('.warp-intro');
  const hyperspaceCanvas = document.querySelector<HTMLCanvasElement>('[data-hyperspace-canvas]');
  let currentPhase: 'jump' | 'arrived' | 'boot' | 'ready' = 'jump';

  const createXenoAudio = () => {
    let context: AudioContext | null = null;
    let master: GainNode | null = null;
    let idleGain: GainNode | null = null;
    let idleStarted = false;
    let warpPlaying = false;
    let noiseBuffer: AudioBuffer | null = null;
    let idlePulseTimer: number | null = null;

    const getContext = () => {
      if (context) return context;

      const AudioContextConstructor = window.AudioContext || (window as typeof window & { webkitAudioContext?: typeof AudioContext }).webkitAudioContext;
      if (!AudioContextConstructor) return null;

      context = new AudioContextConstructor();
      master = context.createGain();
      master.gain.value = 0.32;
      master.connect(context.destination);
      return context;
    };

    const getNoise = (audioContext: AudioContext) => {
      if (noiseBuffer) return noiseBuffer;

      const length = audioContext.sampleRate * 2;
      noiseBuffer = audioContext.createBuffer(1, length, audioContext.sampleRate);
      const data = noiseBuffer.getChannelData(0);
      let last = 0;

      for (let index = 0; index < length; index += 1) {
        last = last * 0.82 + (Math.random() * 2 - 1) * 0.18;
        data[index] = last;
      }

      return noiseBuffer;
    };

    const isReady = () => {
      const audioContext = getContext();
      return Boolean(audioContext && master && audioContext.state === 'running');
    };

    const playTone = (frequency: number, duration: number, gainValue: number, type: OscillatorType = 'sine', detune = 0) => {
      if (!isReady() || !context || !master) return;

      const now = context.currentTime;
      const oscillator = context.createOscillator();
      const gain = context.createGain();
      const filter = context.createBiquadFilter();

      oscillator.type = type;
      oscillator.frequency.setValueAtTime(frequency, now);
      oscillator.frequency.exponentialRampToValueAtTime(Math.max(20, frequency * 0.62), now + duration);
      oscillator.detune.value = detune;
      filter.type = 'lowpass';
      filter.frequency.setValueAtTime(frequency * 2.4, now);
      filter.frequency.exponentialRampToValueAtTime(Math.max(80, frequency * 0.7), now + duration);
      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.exponentialRampToValueAtTime(gainValue, now + 0.018);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

      oscillator.connect(filter);
      filter.connect(gain);
      gain.connect(master);
      oscillator.start(now);
      oscillator.stop(now + duration + 0.04);
    };

    const playNoise = (duration: number, gainValue: number, frequency: number) => {
      if (!isReady() || !context || !master) return;

      const now = context.currentTime;
      const source = context.createBufferSource();
      const gain = context.createGain();
      const filter = context.createBiquadFilter();

      source.buffer = getNoise(context);
      filter.type = 'bandpass';
      filter.frequency.setValueAtTime(frequency, now);
      filter.Q.value = 0.72;
      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.exponentialRampToValueAtTime(gainValue, now + 0.024);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

      source.connect(filter);
      filter.connect(gain);
      gain.connect(master);
      source.start(now);
      source.stop(now + duration + 0.05);
    };

    const playRasp = (duration: number, gainValue: number, frequency: number) => {
      if (!isReady() || !context || !master) return;

      const now = context.currentTime;
      const throat = context.createOscillator();
      const saliva = context.createBufferSource();
      const lfo = context.createOscillator();
      const lfoGain = context.createGain();
      const filter = context.createBiquadFilter();
      const gain = context.createGain();

      throat.type = 'sawtooth';
      throat.frequency.setValueAtTime(frequency * 0.74, now);
      throat.frequency.exponentialRampToValueAtTime(Math.max(24, frequency * 1.16), now + duration * 0.42);
      throat.frequency.exponentialRampToValueAtTime(Math.max(18, frequency * 0.48), now + duration);
      saliva.buffer = getNoise(context);
      filter.type = 'bandpass';
      filter.frequency.setValueAtTime(frequency * 5.8, now);
      filter.frequency.exponentialRampToValueAtTime(Math.max(120, frequency * 2.1), now + duration);
      filter.Q.value = 2.2;
      lfo.type = 'triangle';
      lfo.frequency.value = 18 + Math.random() * 17;
      lfoGain.gain.value = frequency * 1.15;
      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.exponentialRampToValueAtTime(gainValue, now + 0.025);
      gain.gain.setValueAtTime(gainValue * 0.78, now + duration * 0.55);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

      throat.connect(filter);
      saliva.connect(filter);
      lfo.connect(lfoGain);
      lfoGain.connect(filter.frequency);
      filter.connect(gain);
      gain.connect(master);
      throat.start(now);
      saliva.start(now);
      lfo.start(now);
      throat.stop(now + duration + 0.06);
      saliva.stop(now + duration + 0.06);
      lfo.stop(now + duration + 0.06);
    };

    const playChitter = (baseFrequency: number, gainValue: number) => {
      [0, 34, 71].forEach((delay, index) => {
        window.setTimeout(() => {
          const bend = index % 2 ? 1.42 : 0.72;
          playTone(baseFrequency * bend, 0.045 + index * 0.012, gainValue, 'square', index * 17 - 11);
          playNoise(0.035, gainValue * 0.42, baseFrequency * (2.6 + index * 0.34));
        }, delay);
      });
    };

    const startIdle = () => {
      if (idleStarted || !isReady() || !context || !master) return;

      idleStarted = true;
      idleGain = context.createGain();
      idleGain.gain.value = 0.042;
      idleGain.connect(master);

      [26, 39, 53].forEach((frequency, index) => {
        const oscillator = context!.createOscillator();
        const filter = context!.createBiquadFilter();
        const gain = context!.createGain();

        oscillator.type = index === 1 ? 'sawtooth' : 'triangle';
        oscillator.frequency.value = frequency;
        oscillator.detune.value = index * 13 - 16;
        filter.type = 'lowpass';
        filter.frequency.value = 145 + index * 72;
        gain.gain.value = 0.26 - index * 0.045;

        oscillator.connect(filter);
        filter.connect(gain);
        gain.connect(idleGain!);
        oscillator.start();
      });

      const breathSource = context.createBufferSource();
      const breathFilter = context.createBiquadFilter();
      const breathGain = context.createGain();

      breathSource.buffer = getNoise(context);
      breathSource.loop = true;
      breathFilter.type = 'bandpass';
      breathFilter.frequency.value = 310;
      breathFilter.Q.value = 1.15;
      breathGain.gain.value = 0.072;
      breathSource.connect(breathFilter);
      breathFilter.connect(breathGain);
      breathGain.connect(idleGain);
      breathSource.start();

      playRasp(1.8, 0.042, 64);

      idlePulseTimer = window.setInterval(() => {
        if (currentPhase !== 'ready') return;
        playRasp(0.44 + Math.random() * 0.28, 0.038, 42 + Math.random() * 38);
        if (Math.random() > 0.46) {
          playChitter(520 + Math.random() * 260, 0.018);
        }
      }, 3800);
    };

    const stopIdle = () => {
      if (!context || !idleGain) return;
      idleGain.gain.cancelScheduledValues(context.currentTime);
      idleGain.gain.linearRampToValueAtTime(0.0001, context.currentTime + 0.4);
      if (idlePulseTimer) {
        window.clearInterval(idlePulseTimer);
        idlePulseTimer = null;
      }
    };

    return {
      unlock: async (forceFresh = false) => {
        if (forceFresh && context && context.state !== 'running') {
          const staleContext = context;
          context = null;
          master = null;
          idleGain = null;
          idleStarted = false;
          warpPlaying = false;
          noiseBuffer = null;
          if (idlePulseTimer) {
            window.clearInterval(idlePulseTimer);
            idlePulseTimer = null;
          }
          if (staleContext.state !== 'closed') {
            void staleContext.close().catch(() => {});
          }
        }

        const audioContext = getContext();
        if (!audioContext) return false;
        if (audioContext.state !== 'running') {
          try {
            await Promise.race([
              audioContext.resume(),
              new Promise<void>((resolve) => window.setTimeout(resolve, 260))
            ]);
          } catch {
            return false;
          }
        }
        if (audioContext.state === 'running') {
          if (currentPhase === 'ready') startIdle();
          return true;
        }
        return false;
      },
      warp: () => {
        if (!isReady() || warpPlaying || !context || !master) return;

        warpPlaying = true;
        stopIdle();
        const now = context.currentTime;
        const duration = 3.2;
        const low = context.createOscillator();
        const lowGain = context.createGain();
        const pulse = context.createOscillator();
        const pulseGain = context.createGain();

        low.type = 'sawtooth';
        low.frequency.setValueAtTime(42, now);
        low.frequency.exponentialRampToValueAtTime(78, now + 2.15);
        low.frequency.exponentialRampToValueAtTime(34, now + duration);
        lowGain.gain.setValueAtTime(0.0001, now);
        lowGain.gain.exponentialRampToValueAtTime(0.16, now + 0.24);
        lowGain.gain.linearRampToValueAtTime(0.1, now + 2.2);
        lowGain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

        pulse.type = 'triangle';
        pulse.frequency.setValueAtTime(116, now);
        pulse.frequency.exponentialRampToValueAtTime(44, now + duration);
        pulseGain.gain.setValueAtTime(0.0001, now);
        pulseGain.gain.exponentialRampToValueAtTime(0.074, now + 0.16);
        pulseGain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

        low.connect(lowGain);
        pulse.connect(pulseGain);
        lowGain.connect(master);
        pulseGain.connect(master);
        low.start(now);
        pulse.start(now);
        low.stop(now + duration + 0.05);
        pulse.stop(now + duration + 0.05);
        playNoise(duration, 0.13, 900);
        playRasp(duration, 0.11, 52);
        window.setTimeout(() => playRasp(0.62, 0.075, 84), 2140);
        window.setTimeout(() => {
          warpPlaying = false;
        }, duration * 1000);
      },
      arrive: () => {
        playRasp(0.68, 0.13, 46);
        playNoise(0.42, 0.06, 190);
      },
      bootTick: (index: number) => {
        playChitter(300 + index * 55, 0.04);
        playRasp(0.08, 0.024, 86 + index * 9);
      },
      uiHover: () => {
        playChitter(690, 0.018);
      },
      uiSelect: () => {
        playChitter(470, 0.05);
        playRasp(0.12, 0.042, 118);
      },
      vision: () => {
        playRasp(0.22, 0.058, 138);
        playNoise(0.16, 0.045, 2100);
      },
      ready: () => {
        playRasp(0.54, 0.072, 62);
        playChitter(430, 0.028);
        startIdle();
      }
    };
  };

  const xenoAudio = createXenoAudio();
  let xenoAudioUnlocked = false;
  let xenoAudioUnlocking = false;
  let xenoAudioUnlockStarted = 0;
  const audioUnlockEvents = ['pointerdown', 'pointerup', 'touchstart', 'touchend', 'mousedown', 'click', 'keydown'];
  const audioUnlockOptions = { capture: true, passive: true };

  const unlockXenoAudio = (event?: Event) => {
    if (xenoAudioUnlocked) return;

    const fromGesture = Boolean(event?.isTrusted);
    const now = performance.now();
    if (xenoAudioUnlocking && now - xenoAudioUnlockStarted < 300) return;

    xenoAudioUnlocking = true;
    xenoAudioUnlockStarted = now;
    void xenoAudio.unlock(fromGesture).then((unlocked) => {
      xenoAudioUnlocking = false;
      if (!unlocked) return;

      xenoAudioUnlocked = true;
      audioUnlockEvents.forEach((eventName) => {
        window.removeEventListener(eventName, unlockXenoAudio, { capture: true });
      });

      if (unlocked && currentPhase === 'jump') {
        xenoAudio.warp();
      }
    }).catch(() => {
      xenoAudioUnlocking = false;
    });
  };

  unlockXenoAudio();
  window.setTimeout(unlockXenoAudio, 250);
  window.addEventListener('pageshow', unlockXenoAudio);
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') unlockXenoAudio();
  });
  audioUnlockEvents.forEach((eventName) => {
    window.addEventListener(eventName, unlockXenoAudio, audioUnlockOptions);
  });

  const normalizeRoute = (route: string) => {
    if (route === '/') return route;
    return route.endsWith('/') ? route : `${route}/`;
  };

  const setSection = (section: string, route?: string, pushState = true) => {
    if (!shell || !viewport) return;

    shell.dataset.currentSection = section;
    viewport.classList.remove('is-switching');
    window.setTimeout(() => viewport.classList.add('is-switching'), 0);

    sectionPanels.forEach((panel) => {
      const isActive = panel.dataset.sectionPanel === section;
      panel.classList.toggle('is-active', isActive);
    });

    xenoNavButtons.forEach((button) => {
      const isActive = button.dataset.section === section;
      button.classList.toggle('is-active', isActive);
      if (isActive) {
        button.setAttribute('aria-current', 'page');
      } else {
        button.removeAttribute('aria-current');
      }
    });

    radarDots.forEach((dot) => {
      if (dot.dataset.radarSection === section) {
        dot.dataset.active = 'true';
      } else {
        dot.removeAttribute('data-active');
      }
    });

    if (route && pushState && normalizeRoute(window.location.pathname) !== normalizeRoute(route)) {
      window.history.pushState({ section }, '', route);
    }
  };

  const setVisionMode = (mode: string) => {
    if (!shell) return;
    shell.dataset.visionMode = mode;
    visionOptions.forEach((option) => {
      const isActive = option.dataset.visionOption === mode;
      option.classList.toggle('is-active', isActive);
      option.setAttribute('aria-pressed', String(isActive));
    });
  };

  const updateScrollDepth = () => {
    if (!viewport || !scrollDepth || !scrollPercent) return;
    const maxScroll = Math.max(viewport.scrollHeight - viewport.clientHeight, 1);
    const progress = Math.min(100, Math.max(0, Math.round((viewport.scrollTop / maxScroll) * 100)));
    scrollDepth.style.setProperty('--scroll-progress', String(progress));
    scrollPercent.value = `${progress}%`;
    scrollPercent.textContent = `${progress}%`;

    const activeCount = Math.ceil((progress / 100) * 13);
    scrollDepth.querySelectorAll<HTMLElement>('.depth-arc i').forEach((segment, index) => {
      segment.dataset.active = index < activeCount ? 'true' : 'false';
    });
  };

  const setPhase = (phase: 'jump' | 'arrived' | 'boot' | 'ready') => {
    if (!shell) return;
    const phaseChanged = currentPhase !== phase;
    currentPhase = phase;
    shell.dataset.phase = phase;

    if (!phaseChanged && phase !== 'jump') return;

    if (phase === 'jump') {
      xenoAudio.warp();
    } else if (phase === 'arrived') {
      xenoAudio.arrive();
    } else if (phase === 'boot') {
      [1, 2, 3, 4, 5, 6].forEach((order) => {
        window.setTimeout(() => xenoAudio.bootTick(order), order * 115);
      });
    } else if (phase === 'ready') {
      xenoAudio.ready();
    }
  };

  const runHyperspaceJump = () => {
    if (!hyperspaceCanvas) return;

    const context = hyperspaceCanvas.getContext('2d');
    if (!context) return;

    const jumpDuration = 3200;
    const decelStart = 2200;
    const dpr = Math.min(window.devicePixelRatio || 1, 1.6);
    const width = window.innerWidth;
    const height = window.innerHeight;
    const centerX = width / 2;
    const centerY = height / 2;
    const focalLength = Math.min(width, height) * 0.72;
    const starCount = width < 760 ? 260 : 420;
    const calmStarCount = width < 760 ? 90 : 150;
    const colors = [
      [255, 255, 255],
      [197, 239, 247],
      [118, 214, 255],
      [42, 180, 254],
      [165, 210, 255]
    ];

    hyperspaceCanvas.width = Math.floor(width * dpr);
    hyperspaceCanvas.height = Math.floor(height * dpr);
    hyperspaceCanvas.style.width = `${width}px`;
    hyperspaceCanvas.style.height = `${height}px`;
    context.setTransform(dpr, 0, 0, dpr, 0, 0);
    context.lineCap = 'round';

    const resetStar = (star?: {
      x: number;
      y: number;
      z: number;
      previousX: number;
      previousY: number;
      alpha: number;
      size: number;
      color: number[];
    }) => {
      const next = star ?? {
        x: 0,
        y: 0,
        z: 0,
        previousX: centerX,
        previousY: centerY,
        alpha: 1,
        size: 1,
        color: colors[0]
      };
      next.x = (Math.random() - 0.5) * width * 1.28;
      next.y = (Math.random() - 0.5) * height * 1.28;
      next.z = Math.random() * 0.92 + 0.08;
      next.alpha = 0.34 + Math.random() * 0.66;
      next.size = 0.6 + Math.random() * 1.3;
      next.color = colors[Math.floor(Math.random() * colors.length)];
      const projected = project(next);
      next.previousX = projected.x;
      next.previousY = projected.y;
      return next;
    };

    const project = (star: { x: number; y: number; z: number }) => {
      const scale = focalLength / Math.max(star.z * focalLength, 1);
      return {
        x: centerX + star.x * scale,
        y: centerY + star.y * scale
      };
    };

    const stars = Array.from({ length: starCount }, () => resetStar());
    const calmStars = Array.from({ length: calmStarCount }, () => ({
      x: Math.random() * width,
      y: Math.random() * height,
      alpha: 0.25 + Math.random() * 0.55,
      size: Math.random() < 0.82 ? 1 : 1.4,
      speed: 4 + Math.random() * 12,
      driftX: (Math.random() - 0.5) * 1.6,
      driftY: (Math.random() - 0.5) * 1.6,
      twinkle: Math.random() * Math.PI * 2
    }));
    const start = performance.now();
    let frame = 0;
    let calmFrame = 0;
    let calmStarted = false;
    let lastCalmTime = start;

    const resetCalmStar = (star: (typeof calmStars)[number]) => {
      const angle = Math.random() * Math.PI * 2;
      const radius = Math.random() * Math.min(width, height) * 0.22;
      star.x = centerX + Math.cos(angle) * radius;
      star.y = centerY + Math.sin(angle) * radius;
      star.alpha = 0.18 + Math.random() * 0.48;
      star.size = Math.random() < 0.84 ? 1 : 1.35;
      star.speed = 3 + Math.random() * 10;
      star.driftX = (Math.random() - 0.5) * 1.4;
      star.driftY = (Math.random() - 0.5) * 1.4;
      star.twinkle = Math.random() * Math.PI * 2;
    };

    const renderCalmSpace = (time = performance.now(), shouldMove = false) => {
      const delta = Math.min((time - lastCalmTime) / 1000, 0.05);
      lastCalmTime = time;

      context.clearRect(0, 0, width, height);
      context.fillStyle = 'rgb(0, 3, 8)';
      context.fillRect(0, 0, width, height);

      calmStars.forEach((star) => {
        if (shouldMove) {
          const dx = star.x - centerX;
          const dy = star.y - centerY;
          const distance = Math.max(Math.hypot(dx, dy), 1);
          star.x += (dx / distance) * star.speed * delta + star.driftX * delta;
          star.y += (dy / distance) * star.speed * delta + star.driftY * delta;

          if (
            star.x < -24 ||
            star.x > width + 24 ||
            star.y < -24 ||
            star.y > height + 24
          ) {
            resetCalmStar(star);
          }
        }

        const pulse = 0.72 + Math.sin(time * 0.0007 + star.twinkle) * 0.18;
        context.fillStyle = `rgba(210, 248, 255, ${star.alpha * pulse})`;
        context.fillRect(star.x, star.y, star.size, star.size);
      });
    };

    const startCalmSpace = () => {
      if (calmStarted) return;
      calmStarted = true;
      lastCalmTime = performance.now();

      const drift = (time: number) => {
        renderCalmSpace(time, true);
        calmFrame = window.requestAnimationFrame(drift);
      };

      calmFrame = window.requestAnimationFrame(drift);
    };

    const draw = (time: number) => {
      const elapsed = time - start;
      const progress = Math.min(elapsed / jumpDuration, 1);
      const decelProgress = elapsed < decelStart ? 0 : Math.min((elapsed - decelStart) / (jumpDuration - decelStart), 1);
      const easeOut = 1 - Math.pow(1 - decelProgress, 3);
      const speed = 0.042 - easeOut * 0.035;
      const lineScale = 1 - easeOut * 0.72;
      const fade = 1 - easeOut * 0.22;

      context.clearRect(0, 0, width, height);
      context.fillStyle = `rgba(0, 4, 12, ${0.86 - easeOut * 0.18})`;
      context.fillRect(0, 0, width, height);

      stars.forEach((star) => {
        star.previousX = project(star).x;
        star.previousY = project(star).y;
        star.z -= speed;

        if (star.z <= 0.018) {
          resetStar(star);
          return;
        }

        const current = project(star);
        if (
          current.x < -width * 0.15 ||
          current.x > width * 1.15 ||
          current.y < -height * 0.15 ||
          current.y > height * 1.15
        ) {
          resetStar(star);
          return;
        }

        const [r, g, b] = star.color;

        context.beginPath();
        context.moveTo(star.previousX, star.previousY);
        context.lineTo(
          star.previousX + (current.x - star.previousX) * Math.max(lineScale, 0.12),
          star.previousY + (current.y - star.previousY) * Math.max(lineScale, 0.12)
        );
        context.lineWidth = star.size * (1.65 - easeOut * 0.85);
        context.strokeStyle = `rgba(${r}, ${g}, ${b}, ${star.alpha * fade})`;
        context.stroke();
      });

      if (progress < 1) {
        frame = window.requestAnimationFrame(draw);
      } else {
        startCalmSpace();
      }
    };

    frame = window.requestAnimationFrame(draw);
    window.setTimeout(() => {
      window.cancelAnimationFrame(frame);
      if (!calmStarted) startCalmSpace();
    }, jumpDuration + 80);
  };

  const bootCockpit = () => {
    if (!shell) return;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduceMotion) {
      setPhase('ready');
      return;
    }

    setPhase('jump');
    runHyperspaceJump();
    window.setTimeout(() => {
      setPhase('arrived');
    }, 3200);
    window.setTimeout(() => {
      setPhase('boot');
    }, 3700);
    window.setTimeout(() => {
      setPhase('ready');
    }, 4600);
  };

  xenoNavButtons.forEach((button) => {
    button.addEventListener('pointerenter', () => {
      xenoAudio.uiHover();
    });

    button.addEventListener('pointermove', (event) => {
      const rect = button.getBoundingClientRect();
      button.style.setProperty('--cursor-x', `${event.clientX - rect.left}px`);
      button.style.setProperty('--cursor-y', `${event.clientY - rect.top}px`);
    });

    button.addEventListener('click', (event) => {
      const section = button.dataset.section;
      const route = button.dataset.route;
      if (!section || !route || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

      event.preventDefault();
      xenoAudio.uiSelect();
      setSection(section, route);
    });
  });

  visionOptions.forEach((option) => {
    option.addEventListener('pointerenter', () => {
      xenoAudio.uiHover();
    });

    option.addEventListener('click', () => {
      xenoAudio.vision();
      setVisionMode(option.dataset.visionOption ?? 'visible');
    });
  });

  viewport?.addEventListener('scroll', updateScrollDepth, { passive: true });
  window.addEventListener('popstate', () => {
    const matchingButton = xenoNavButtons.find((button) => normalizeRoute(button.dataset.route ?? '') === normalizeRoute(window.location.pathname));
    setSection(matchingButton?.dataset.section ?? 'home', undefined, false);
  });

  setSection(shell?.dataset.currentSection ?? 'projects', undefined, false);
  setVisionMode('visible');
  updateScrollDepth();
  bootCockpit();
</script>

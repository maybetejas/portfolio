---
import ScrollDepthMeter from './ScrollDepthMeter.astro';
import SystemStats from './SystemStats.astro';
import VisionModeSwitch from './VisionModeSwitch.astro';

const navItems = [
  {
    href: '/projects/',
    section: 'projects',
    label: 'PROJECTS',
    radarX: 34,
    radarY: 48,
    icon: '<path d="M4.5 7.5h15v10h-15z" /><path d="M8 11h8" /><path d="M8 14h5" />'
  },
  {
    href: '/tech-stack/',
    section: 'skills',
    label: 'SKILLS',
    radarX: 42,
    radarY: 36,
    icon: '<path d="M12 4.5v15" /><path d="M5.5 9h13" /><path d="M7.5 15h9" /><path d="M8.5 4.5l7 15" /><path d="M15.5 4.5l-7 15" />'
  },
  {
    href: '/experience/',
    section: 'experience',
    label: 'EXP',
    radarX: 50,
    radarY: 64,
    icon: '<path d="M6 19V7.5l6-3 6 3V19" /><path d="M9 10h6" /><path d="M9 13h6" /><path d="M9 16h6" />'
  },
  {
    href: '/',
    section: 'home',
    label: 'HOME',
    radarX: 36,
    radarY: 60,
    icon: '<path d="M5.5 14.5 12 7.5l6.5 7" /><path d="M8.25 13.75V20h7.5v-6.25" />'
  },
  {
    href: '/about/',
    section: 'about',
    label: 'ABOUT',
    radarX: 58,
    radarY: 38,
    icon: '<path d="M12 4.5c2.4 2.5 4.2 5.2 4.2 8.1 0 2.7-1.6 4.8-4.2 6.9-2.6-2.1-4.2-4.2-4.2-6.9 0-2.9 1.8-5.6 4.2-8.1Z" /><path d="M12 13.5v6" />'
  },
  {
    href: '/blog/',
    section: 'blog',
    label: 'BLOG',
    radarX: 66,
    radarY: 50,
    icon: '<path d="M6.5 5.5h8l3 3v10h-11z" /><path d="M14.5 5.5v3h3" /><path d="M9 12h6" /><path d="M9 15h5" />'
  },
  {
    href: '/contact/',
    section: 'contact',
    label: 'COMMS',
    radarX: 74,
    radarY: 62,
    icon: '<path d="M4.5 7.5 12 13l7.5-5.5" /><path d="M5 7h14v10H5z" /><path d="M8 17l3-3" /><path d="M16 17l-3-3" />'
  }
];

const normalizePath = (path: string) => {
  if (path === '/') return path;
  return path.endsWith('/') ? path : `${path}/`;
};

const currentPath = normalizePath(Astro.url.pathname);
const isActiveNavItem = (href: string) => href === '/' ? currentPath === href : currentPath.startsWith(href);
const activeNavItem = navItems.find((item) => isActiveNavItem(item.href)) ?? navItems.find((item) => item.section === 'home') ?? navItems[0];
const centerNavIndex = Math.floor(navItems.length / 2);
const activeNavIndex = Math.max(navItems.findIndex((item) => item.section === activeNavItem.section), 0);
---

<div class="cockpit-shell" data-cockpit-shell data-current-section={activeNavItem.section} data-vision-mode="visible" data-hud-visibility="visible" data-phase="jump" data-reveal-phase="dark">
  <div class="space-background" aria-hidden="true">
    <section class="spectrum-space-layer spectrum-stars spectrum-stars--tiny" data-space-parallax="1">
      <div class="spectrum-star-field" data-space-stars="tiny"></div>
    </section>
    <section class="spectrum-space-layer spectrum-stars spectrum-stars--large" data-space-parallax="2">
      <div class="spectrum-star-field" data-space-stars="large"></div>
    </section>
    <section class="spectrum-space-layer spectrum-stars spectrum-stars--uv" data-space-parallax="3">
      <div class="spectrum-star-field" data-space-stars="uv"></div>
    </section>
    <span class="space-layer sensor-sweep"></span>
    <span class="spectrum-viewport-mask"></span>
  </div>
  <div class="warp-intro" aria-hidden="true">
    <canvas class="hyperspace-canvas" data-hyperspace-canvas></canvas>
  </div>
  <div class="glass-overlay" aria-hidden="true"></div>

  <div class="hud-stage" aria-hidden="true">
    <div class="hud-projection" data-hud-projection>
      <picture class="hud-frame" aria-hidden="true">
        <source media="(max-width: 760px)" srcset="/assets/frameMobile.png" />
        <img src="/assets/framePC.png" alt="" loading="eager" decoding="async" />
      </picture>
    </div>
  </div>

  <div class="nav-system" data-nav-system>
    <SystemStats />
    <VisionModeSwitch />
    <ScrollDepthMeter />

    <button class="xeno-menu-toggle hud-boot-item" type="button" data-xeno-menu-toggle data-boot-order="5" aria-expanded="false" aria-controls="xeno-primary-nav">
      <span class="xeno-menu-toggle__icon" aria-hidden="true"></span>
      <span class="xeno-menu-toggle__label" data-xeno-menu-label>{activeNavItem.label}</span>
    </button>

    <nav class="xeno-navbar hud-boot-item" id="xeno-primary-nav" aria-label="Primary navigation" data-xeno-navbar data-boot-order="5" data-expanded="false">
      {
        navItems.map((item, index) => (
          <a
            href={item.href}
            class={`xeno-nav-button${index === activeNavIndex ? ' is-active' : ''}`}
            data-xeno-nav-button
            data-section={item.section}
            data-route={item.href}
            data-depth={Math.min(Math.abs(index - centerNavIndex), 2)}
            aria-current={isActiveNavItem(item.href) ? 'page' : undefined}
            style={`--button-index: ${index}; --boot-distance: ${Math.abs(index - centerNavIndex)};`}
          >
            <svg class="xeno-veins" viewBox="0 0 100 56" preserveAspectRatio="none" aria-hidden="true">
              <path class="vein vein-a" d="M50 30 C42 25 39 17 30 14 C21 11 18 8 12 4" />
              <path class="vein vein-b" d="M50 29 C40 32 34 38 25 37 C18 36 14 42 7 47" />
              <path class="vein vein-c" d="M50 29 C58 24 62 16 70 14 C79 12 84 7 91 5" />
              <path class="vein vein-d" d="M50 31 C61 34 66 41 76 39 C84 38 88 43 95 49" />
              <path class="vein vein-e" d="M50 29 C45 20 49 15 43 9 C39 5 35 4 31 2" />
              <path class="vein vein-f" d="M51 29 C56 21 53 14 59 9 C63 5 68 5 73 2" />
              <path class="vein vein-g" d="M49 31 C42 35 43 43 36 47 C31 50 27 50 21 54" />
              <path class="vein vein-h" d="M51 31 C58 36 57 44 64 48 C70 51 75 50 82 54" />
            </svg>

            <span class="xeno-core">
              <svg
                class="xeno-icon"
                viewBox="0 0 24 24"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <Fragment set:html={item.icon} />
              </svg>
              <span class="xeno-label">{item.label}</span>
            </span>
          </a>
        ))
      }
    </nav>

    <aside class="travel-widget hud-boot-item" data-travel-widget data-expanded="false" data-boot-order="3" aria-label="Travel destinations">
      <span class="stats-corner stats-corner--tl" aria-hidden="true"><i></i></span>
      <span class="stats-corner stats-corner--tr" aria-hidden="true"><i></i></span>
      <span class="stats-corner stats-corner--bl" aria-hidden="true"><i></i></span>
      <span class="stats-corner stats-corner--br" aria-hidden="true"><i></i></span>
      <span class="stats-opener" aria-hidden="true"></span>
      <button class="travel-toggle" type="button" data-travel-toggle aria-expanded="false">TRAVEL</button>
      <div class="travel-panel" aria-hidden="true">
        <span>NEW LOCATIONS</span>
        <strong>COMING SOON</strong>
      </div>
    </aside>

    <div class="portfolio-radar hud-boot-item" data-boot-order="4" aria-label="Active scanner tracking nearby space signals." role="img">
      <div class="radar-plane" aria-hidden="true">
        <span class="radar-ring radar-ring--outer"></span>
        <span class="radar-ring radar-ring--inner radar-ring--one"></span>
        <span class="radar-ring radar-ring--inner radar-ring--two"></span>
        <span class="radar-ring radar-ring--inner radar-ring--three"></span>
        <span class="radar-axis radar-axis--vertical"></span>
        <span class="radar-axis radar-axis--horizontal"></span>
        <span class="radar-sweep"></span>
        <span class="radar-dot radar-dot--ship" data-active="true" style="--radar-x: 50%; --radar-y: 50%; --blink-delay: 0ms;"></span>
        <span class="radar-dot radar-dot--signal" style="--radar-x: 31%; --radar-y: 38%; --blink-delay: 140ms;"></span>
        <span class="radar-dot radar-dot--signal" style="--radar-x: 68%; --radar-y: 32%; --blink-delay: 620ms;"></span>
        <span class="radar-dot radar-dot--signal" style="--radar-x: 73%; --radar-y: 56%; --blink-delay: 1080ms;"></span>
        <span class="radar-dot radar-dot--signal" style="--radar-x: 41%; --radar-y: 73%; --blink-delay: 1560ms;"></span>
        <span class="radar-dot radar-dot--signal" style="--radar-x: 24%; --radar-y: 62%; --blink-delay: 2040ms;"></span>
      </div>
    </div>
  </div>

  <main class="content-viewport" data-content-viewport tabindex="-1">
    <div class="page-slot">
      <slot />
    </div>
  </main>
</div>

<script>
  const shell = document.querySelector<HTMLElement>('[data-cockpit-shell]');
  const viewport = document.querySelector<HTMLElement>('[data-content-viewport]');
  const xenoNavbar = document.querySelector<HTMLElement>('[data-xeno-navbar]');
  const xenoMenuToggle = document.querySelector<HTMLButtonElement>('[data-xeno-menu-toggle]');
  const xenoMenuLabel = document.querySelector<HTMLElement>('[data-xeno-menu-label]');
  const xenoNavButtons = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-xeno-nav-button]'));
  const sectionPanels = Array.from(document.querySelectorAll<HTMLElement>('[data-section-panel]'));
  const visionOptions = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-vision-option]'));
  const visionSwitch = document.querySelector<HTMLElement>('.vision-switch');
  const spectrumToggle = document.querySelector<HTMLButtonElement>('[data-spectrum-toggle]');
  const spectrumLabel = document.querySelector<HTMLElement>('[data-spectrum-label]');
  const hudToggle = document.querySelector<HTMLButtonElement>('[data-hud-toggle]');
  const hudToggleLabel = document.querySelector<HTMLElement>('[data-hud-toggle-label]');
  const travelWidget = document.querySelector<HTMLElement>('[data-travel-widget]');
  const travelToggle = document.querySelector<HTMLButtonElement>('[data-travel-toggle]');
  const scrollDepth = document.querySelector<HTMLElement>('[data-scroll-depth]');
  const scrollPercent = document.querySelector<HTMLOutputElement>('[data-scroll-percent]');
  const warpIntro = document.querySelector<HTMLElement>('.warp-intro');
  const hyperspaceCanvas = document.querySelector<HTMLCanvasElement>('[data-hyperspace-canvas]');
  type CockpitPhase = 'jump' | 'arrived' | 'boot' | 'ready';
  type RevealPhase = 'dark' | 'wake' | 'awake' | 'charge' | 'settled';
  type VisionMode = 'visible' | 'uv' | 'ir';
  let currentPhase: CockpitPhase = 'jump';
  let currentVisionMode: VisionMode = 'visible';
  let visionModeTimers: number[] = [];
  let spectrumCollapseTimer = 0;
  let travelCollapseTimer = 0;
  let activeSection = shell?.dataset.currentSection ?? 'home';
  let sectionSwitchTimer = 0;
  const panelIntroDuration = 2100;
  const mobileMedia = window.matchMedia('(max-width: 760px)');
  const lowPowerMedia = window.matchMedia('(hover: none), (pointer: coarse), (max-width: 760px)');
  let spectrumSpaceInitialized = false;
  let uvStarsPopulated = false;
  let uvStarsStarted = false;
  let uvStarsCreated = 0;
  let spaceAnimationFrame = 0;
  let lastSpacePointerMove = 0;

  const spaceLayers = Array.from(document.querySelectorAll<HTMLElement>('[data-space-parallax]')).map((element) => ({
    element,
    depth: Number(element.dataset.spaceParallax),
    x: 0,
    y: 0
  }));
  const spacePointer = {
    targetX: 0,
    targetY: 0,
    easedX: 0,
    easedY: 0,
    active: false
  };
  const PARALLAX_RANGE_PX = 1.65;
  const POINTER_EASE = 0.045;
  const IDLE_DECAY = 0.94;
  const STAR_COUNTS = {
    tiny: mobileMedia.matches ? 95 : 180,
    large: mobileMedia.matches ? 14 : 26,
    uv: mobileMedia.matches ? 180 : 360
  };
  const UV_BATCH_SIZE = mobileMedia.matches ? 45 : 80;
  const SPIKE_STAR_COUNT = mobileMedia.matches ? 1 : 2;
  const LANDMARK_STARS = [
    { x: 5.7, y: 17.2, size: 2.9, tone: 'var(--star-amber-color)', alpha: 0.90, glow: 14, flare: 42, angle: -1 },
    { x: 24.8, y: 70.5, size: 2.2, tone: 'var(--star-amber-color)', alpha: 0.82, glow: 11, flare: 32, angle: -12 },
    { x: 44.2, y: 15.7, size: 2.3, tone: 'var(--star-white-color)', alpha: 0.86, glow: 12, flare: 34, angle: 2 },
    { x: 59.8, y: 71.1, size: 2.8, tone: 'var(--star-blue-color)', alpha: 0.88, glow: 14, flare: 40, angle: 9 },
    { x: 74.8, y: 58.8, size: 2.4, tone: 'var(--star-amber-color)', alpha: 0.84, glow: 12, flare: 36, angle: 5 },
    { x: 91.4, y: 33.8, size: 1.8, tone: 'var(--star-red-color)', alpha: 0.72, glow: 9, flare: 24, angle: 16 }
  ];
  const clusterScale = mobileMedia.matches ? 0.22 : 0.38;
  const STAR_CLUSTERS = [
    { x: 9.5, y: 78.4, count: Math.max(2, Math.round(18 * clusterScale)), spread: 3.5, tone: 'var(--star-cool-color)' },
    { x: 39.5, y: 63.8, count: Math.max(2, Math.round(22 * clusterScale)), spread: 4.3, tone: 'var(--star-warm-color)' },
    { x: 63.2, y: 35.0, count: Math.max(2, Math.round(20 * clusterScale)), spread: 3.9, tone: 'var(--star-blue-color)' },
    { x: 83.0, y: 52.8, count: Math.max(2, Math.round(24 * clusterScale)), spread: 5.4, tone: 'var(--star-amber-color)' },
    { x: 71.6, y: 82.0, count: Math.max(2, Math.round(16 * clusterScale)), spread: 4.0, tone: 'var(--star-red-color)' }
  ];
  const FAR_STARS = [
    { x: 11.2, y: 24.5, size: 15.5, tone: 'var(--star-white-color)', alpha: 0.28, glow: 20 },
    { x: 34.8, y: 16.0, size: 10.8, tone: 'var(--star-blue-color)', alpha: 0.22, glow: 16 },
    { x: 53.6, y: 77.6, size: 18.5, tone: 'var(--star-warm-color)', alpha: 0.20, glow: 22 },
    { x: 78.4, y: 32.8, size: 13.4, tone: 'var(--star-amber-color)', alpha: 0.24, glow: 18 },
    { x: 88.8, y: 69.4, size: 11.2, tone: 'var(--star-cool-color)', alpha: 0.18, glow: 15 },
    { x: 18.5, y: 86.0, size: 19.8, tone: 'var(--star-red-color)', alpha: 0.16, glow: 21 },
    { x: 66.0, y: 11.8, size: 12.6, tone: 'var(--star-white-color)', alpha: 0.20, glow: 17 }
  ];

  const createSeededRandom = (seed: number) => () => {
    seed |= 0;
    seed = seed + 0x6D2B79F5 | 0;
    let value = Math.imul(seed ^ seed >>> 15, 1 | seed);
    value ^= value + Math.imul(value ^ value >>> 7, 61 | value);
    return ((value ^ value >>> 14) >>> 0) / 4294967296;
  };

  const seededRandom = createSeededRandom(780199);
  const randomBetween = (min: number, max: number) => min + seededRandom() * (max - min);
  const pickStarTone = () => {
    const tones = [
      'var(--star-color)',
      'var(--star-color)',
      'var(--star-color)',
      'var(--star-warm-color)',
      'var(--star-warm-color)',
      'var(--star-cool-color)',
      'var(--star-cool-color)',
      'var(--star-hot-color)',
      'var(--star-white-color)',
      'var(--star-amber-color)',
      'var(--star-blue-color)',
      'var(--star-red-color)'
    ];
    return tones[Math.floor(seededRandom() * tones.length)];
  };

  const setStarVars = (
    star: HTMLElement,
    config: { x: number; y: number; size: number; alpha: number; tone: string; glow?: number; flare?: number; angle?: number }
  ) => {
    star.style.setProperty('--x', config.x.toFixed(3));
    star.style.setProperty('--y', config.y.toFixed(3));
    star.style.setProperty('--size', config.size.toFixed(3));
    star.style.setProperty('--alpha', config.alpha.toFixed(3));
    star.style.setProperty('--tone', config.tone);
    star.style.setProperty('--glow', (config.glow ?? randomBetween(4, 15)).toFixed(2));
    star.style.setProperty('--flare', (config.flare ?? randomBetween(14, 42)).toFixed(2));
    star.style.setProperty('--flare-angle', `${(config.angle ?? randomBetween(-18, 18)).toFixed(2)}deg`);
  };

  const createSpectrumStar = ({ large = false } = {}) => {
    const star = document.createElement('span');
    const bright = large && seededRandom() > 0.985;
    const rareGiant = seededRandom() > 0.992;
    const size = large
      ? (rareGiant ? randomBetween(3.6, 4.9) : randomBetween(1.0, 3.4))
      : randomBetween(0.28, 1.62);
    const alpha = large ? randomBetween(0.38, 0.92) : randomBetween(0.14, 0.84);

    star.className = bright ? 'spectrum-star is-bright' : 'spectrum-star';
    setStarVars(star, {
      x: randomBetween(0.5, 99.5),
      y: randomBetween(0.5, 99.5),
      size,
      alpha,
      tone: pickStarTone()
    });
    return star;
  };

  const createUvSpectrumStar = () => {
    const star = document.createElement('span');
    const roll = seededRandom();
    const giant = roll > 0.985;
    const hot = roll > 0.94;
    const size = giant ? randomBetween(2.5, 4.6) : hot ? randomBetween(0.9, 2.2) : randomBetween(0.28, 1.08);
    const alpha = giant ? randomBetween(0.78, 0.98) : hot ? randomBetween(0.52, 0.92) : randomBetween(0.24, 0.72);
    const tone = seededRandom() > 0.62 ? 'var(--uv-secondary-color)' : 'var(--uv-core-color)';

    star.className = giant ? 'spectrum-star is-uv-giant' : hot ? 'spectrum-star is-uv-hot' : 'spectrum-star';
    setStarVars(star, {
      x: randomBetween(0.5, 99.5),
      y: randomBetween(0.5, 99.5),
      size,
      alpha,
      tone,
      glow: giant ? randomBetween(12, 24) : hot ? randomBetween(6, 14) : randomBetween(2.5, 8.5),
      flare: giant ? randomBetween(22, 44) : randomBetween(8, 20),
      angle: randomBetween(-16, 16)
    });
    return star;
  };

  const createLandmarkStar = (config: (typeof LANDMARK_STARS)[number]) => {
    const star = document.createElement('span');
    star.className = 'spectrum-star is-bright is-landmark';
    setStarVars(star, config);
    return star;
  };

  const createFarStar = (config: (typeof FAR_STARS)[number]) => {
    const star = document.createElement('span');
    star.className = 'spectrum-far-star';
    setStarVars(star, config);
    return star;
  };

  const createClusterStar = (cluster: (typeof STAR_CLUSTERS)[number]) => {
    const star = document.createElement('span');
    const offsetX = randomBetween(-cluster.spread, cluster.spread);
    const offsetY = randomBetween(-cluster.spread, cluster.spread);
    star.className = 'spectrum-star';
    setStarVars(star, {
      x: Math.max(0.5, Math.min(99.5, cluster.x + offsetX)),
      y: Math.max(0.5, Math.min(99.5, cluster.y + offsetY)),
      size: randomBetween(0.28, 1.22),
      alpha: randomBetween(0.22, 0.72),
      tone: cluster.tone,
      glow: randomBetween(3, 7),
      flare: randomBetween(8, 20),
      angle: randomBetween(-12, 12)
    });
    return star;
  };

  const createSpikeStar = () => {
    const star = document.createElement('span');
    const core = document.createElement('span');
    star.className = 'spectrum-spike-star';
    core.className = 'core';
    star.style.setProperty('--x', randomBetween(8, 94).toFixed(3));
    star.style.setProperty('--y', randomBetween(9, 88).toFixed(3));
    star.style.setProperty('--s', randomBetween(6, 10).toFixed(2));
    star.style.setProperty('--o', randomBetween(0.58, 0.86).toFixed(3));
    star.style.setProperty('--r', `${randomBetween(-18, 18).toFixed(2)}deg`);
    star.style.setProperty('--tone', pickStarTone());
    star.appendChild(core);
    return star;
  };

  const populateStarContainer = (type: 'tiny' | 'large', count: number) => {
    const container = document.querySelector<HTMLElement>(`[data-space-stars="${type}"]`);
    if (!container) return;

    const fragment = document.createDocumentFragment();
    for (let index = 0; index < count; index += 1) {
      fragment.appendChild(createSpectrumStar({ large: type === 'large' }));
    }
    container.replaceChildren(fragment);
  };

  const addSpacePointsOfInterest = () => {
    const container = document.querySelector<HTMLElement>('[data-space-stars="large"]');
    if (!container) return;

    const fragment = document.createDocumentFragment();
    LANDMARK_STARS.forEach((landmark) => fragment.appendChild(createLandmarkStar(landmark)));
    FAR_STARS.forEach((farStar) => fragment.appendChild(createFarStar(farStar)));
    STAR_CLUSTERS.forEach((cluster) => {
      for (let index = 0; index < cluster.count; index += 1) {
        fragment.appendChild(createClusterStar(cluster));
      }
    });
    for (let index = 0; index < SPIKE_STAR_COUNT; index += 1) {
      fragment.appendChild(createSpikeStar());
    }
    container.appendChild(fragment);
  };

  const scheduleUvBatch = (callback: (deadline?: IdleDeadline) => void) => {
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(callback, { timeout: 160 });
      return;
    }
    window.setTimeout(() => callback(), 16);
  };

  const populateUvSpectrumStars = () => {
    if (uvStarsPopulated || uvStarsStarted) return;

    uvStarsStarted = true;
    const container = document.querySelector<HTMLElement>('[data-space-stars="uv"]');
    if (!container) return;

    const appendBatch = (deadline?: IdleDeadline) => {
      const fragment = document.createDocumentFragment();
      const batchEnd = Math.min(uvStarsCreated + UV_BATCH_SIZE, STAR_COUNTS.uv);

      while (uvStarsCreated < batchEnd && (!deadline || deadline.didTimeout || deadline.timeRemaining() > 1)) {
        fragment.appendChild(createUvSpectrumStar());
        uvStarsCreated += 1;
      }

      container.appendChild(fragment);

      if (uvStarsCreated < STAR_COUNTS.uv) {
        scheduleUvBatch(appendBatch);
        return;
      }

      uvStarsPopulated = true;
    };

    container.replaceChildren();
    scheduleUvBatch(appendBatch);
  };

  const animateSpectrumSpace = () => {
    spaceAnimationFrame = 0;
    const isInputIdle = performance.now() - lastSpacePointerMove > 120;

    if (isInputIdle) {
      spacePointer.active = false;
    }

    if (!spacePointer.active) {
      spacePointer.targetX *= IDLE_DECAY;
      spacePointer.targetY *= IDLE_DECAY;
    }

    spacePointer.easedX += (spacePointer.targetX - spacePointer.easedX) * POINTER_EASE;
    spacePointer.easedY += (spacePointer.targetY - spacePointer.easedY) * POINTER_EASE;

    spaceLayers.forEach((layer) => {
      layer.x = spacePointer.easedX * PARALLAX_RANGE_PX * layer.depth;
      layer.y = spacePointer.easedY * PARALLAX_RANGE_PX * layer.depth;
      layer.element.style.setProperty('--px', layer.x.toFixed(3));
      layer.element.style.setProperty('--py', layer.y.toFixed(3));
    });

    if (spacePointer.active || Math.abs(spacePointer.easedX) > 0.004 || Math.abs(spacePointer.easedY) > 0.004) {
      scheduleSpectrumAnimation();
    }
  };

  const scheduleSpectrumAnimation = () => {
    if (!spaceAnimationFrame) {
      spaceAnimationFrame = requestAnimationFrame(animateSpectrumSpace);
    }
  };

  const setSpacePointerTarget = (clientX: number, clientY: number) => {
    const halfWidth = window.innerWidth / 2;
    const halfHeight = window.innerHeight / 2;
    spacePointer.targetX = (clientX - halfWidth) / halfWidth;
    spacePointer.targetY = (clientY - halfHeight) / halfHeight;
    spacePointer.active = true;
    lastSpacePointerMove = performance.now();
    scheduleSpectrumAnimation();
  };

  const initializeSpectrumSpace = () => {
    if (spectrumSpaceInitialized) return;

    spectrumSpaceInitialized = true;
    populateStarContainer('tiny', STAR_COUNTS.tiny);
    populateStarContainer('large', STAR_COUNTS.large);
    addSpacePointsOfInterest();

    if (!lowPowerMedia.matches) {
      window.addEventListener('pointermove', (event) => setSpacePointerTarget(event.clientX, event.clientY), { passive: true });
      window.addEventListener('pointerleave', () => {
        spacePointer.active = false;
        scheduleSpectrumAnimation();
      });
      window.addEventListener('blur', () => {
        spacePointer.active = false;
        scheduleSpectrumAnimation();
      });
    }
  };

  const createXenoAudio = () => {
    let context: AudioContext | null = null;
    let master: GainNode | null = null;
    let idleGain: GainNode | null = null;
    let idleStarted = false;
    let warpPlaying = false;
    let noiseBuffer: AudioBuffer | null = null;
    let idlePulseTimer: number | null = null;
    const touchAudioTarget = window.matchMedia('(hover: none), (pointer: coarse)').matches;
    const masterVolume = touchAudioTarget ? 0.82 : 0.68;
    const effectBoost = touchAudioTarget ? 2.25 : 1.8;
    const idleBoost = touchAudioTarget ? 1.7 : 1.4;
    const boostGain = (gainValue: number, multiplier = effectBoost) => Math.min(gainValue * multiplier, 0.28);

    const getContext = () => {
      if (context) return context;

      const AudioContextConstructor = window.AudioContext || (window as typeof window & { webkitAudioContext?: typeof AudioContext }).webkitAudioContext;
      if (!AudioContextConstructor) return null;

      context = new AudioContextConstructor();
      master = context.createGain();
      const limiter = context.createDynamicsCompressor();
      master.gain.value = masterVolume;
      limiter.threshold.value = -12;
      limiter.knee.value = 16;
      limiter.ratio.value = 5;
      limiter.attack.value = 0.004;
      limiter.release.value = 0.18;
      master.connect(limiter);
      limiter.connect(context.destination);
      return context;
    };

    const getNoise = (audioContext: AudioContext) => {
      if (noiseBuffer) return noiseBuffer;

      const length = audioContext.sampleRate * 2;
      noiseBuffer = audioContext.createBuffer(1, length, audioContext.sampleRate);
      const data = noiseBuffer.getChannelData(0);
      let last = 0;

      for (let index = 0; index < length; index += 1) {
        last = last * 0.82 + (Math.random() * 2 - 1) * 0.18;
        data[index] = last;
      }

      return noiseBuffer;
    };

    const isReady = () => {
      const audioContext = getContext();
      return Boolean(audioContext && master && audioContext.state === 'running');
    };

    const playWhenReady = (callback: () => void) => {
      const audioContext = getContext();
      if (!audioContext || !master) return;

      if (audioContext.state === 'running') {
        callback();
        return;
      }

      void audioContext.resume().then(() => {
        if (audioContext.state === 'running') callback();
      }).catch(() => {});
    };

    const playTone = (frequency: number, duration: number, gainValue: number, type: OscillatorType = 'sine', detune = 0) => {
      playWhenReady(() => {
        if (!context || !master) return;

        const now = context.currentTime;
        const outputGain = boostGain(gainValue);
        const oscillator = context.createOscillator();
        const gain = context.createGain();
        const filter = context.createBiquadFilter();

        oscillator.type = type;
        oscillator.frequency.setValueAtTime(frequency, now);
        oscillator.frequency.exponentialRampToValueAtTime(Math.max(20, frequency * 0.62), now + duration);
        oscillator.detune.value = detune;
        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(frequency * 2.4, now);
        filter.frequency.exponentialRampToValueAtTime(Math.max(80, frequency * 0.7), now + duration);
        gain.gain.setValueAtTime(0.0001, now);
        gain.gain.exponentialRampToValueAtTime(outputGain, now + 0.018);
        gain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

        oscillator.connect(filter);
        filter.connect(gain);
        gain.connect(master);
        oscillator.start(now);
        oscillator.stop(now + duration + 0.04);
      });
    };

    const playNoise = (duration: number, gainValue: number, frequency: number) => {
      playWhenReady(() => {
        if (!context || !master) return;

        const now = context.currentTime;
        const outputGain = boostGain(gainValue);
        const source = context.createBufferSource();
        const gain = context.createGain();
        const filter = context.createBiquadFilter();

        source.buffer = getNoise(context);
        filter.type = 'bandpass';
        filter.frequency.setValueAtTime(touchAudioTarget ? Math.max(frequency, 520) : frequency, now);
        filter.Q.value = 0.72;
        gain.gain.setValueAtTime(0.0001, now);
        gain.gain.exponentialRampToValueAtTime(outputGain, now + 0.024);
        gain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

        source.connect(filter);
        filter.connect(gain);
        gain.connect(master);
        source.start(now);
        source.stop(now + duration + 0.05);
      });
    };

    const playRasp = (duration: number, gainValue: number, frequency: number) => {
      playWhenReady(() => {
        if (!context || !master) return;

        const now = context.currentTime;
        const outputGain = boostGain(gainValue);
        const throat = context.createOscillator();
        const saliva = context.createBufferSource();
        const lfo = context.createOscillator();
        const lfoGain = context.createGain();
        const filter = context.createBiquadFilter();
        const gain = context.createGain();

        throat.type = 'sawtooth';
        throat.frequency.setValueAtTime(frequency * 0.74, now);
        throat.frequency.exponentialRampToValueAtTime(Math.max(24, frequency * 1.16), now + duration * 0.42);
        throat.frequency.exponentialRampToValueAtTime(Math.max(18, frequency * 0.48), now + duration);
        saliva.buffer = getNoise(context);
        filter.type = 'bandpass';
        filter.frequency.setValueAtTime(touchAudioTarget ? Math.max(frequency * 5.8, 620) : frequency * 5.8, now);
        filter.frequency.exponentialRampToValueAtTime(Math.max(touchAudioTarget ? 280 : 120, frequency * 2.1), now + duration);
        filter.Q.value = 2.2;
        lfo.type = 'triangle';
        lfo.frequency.value = 18 + Math.random() * 17;
        lfoGain.gain.value = frequency * 1.15;
        gain.gain.setValueAtTime(0.0001, now);
        gain.gain.exponentialRampToValueAtTime(outputGain, now + 0.025);
        gain.gain.setValueAtTime(outputGain * 0.78, now + duration * 0.55);
        gain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

        throat.connect(filter);
        saliva.connect(filter);
        lfo.connect(lfoGain);
        lfoGain.connect(filter.frequency);
        filter.connect(gain);
        gain.connect(master);
        throat.start(now);
        saliva.start(now);
        lfo.start(now);
        throat.stop(now + duration + 0.06);
        saliva.stop(now + duration + 0.06);
        lfo.stop(now + duration + 0.06);
      });
    };

    const playChitter = (baseFrequency: number, gainValue: number) => {
      [0, 34, 71].forEach((delay, index) => {
        window.setTimeout(() => {
          const bend = index % 2 ? 1.42 : 0.72;
          playTone(baseFrequency * bend, 0.045 + index * 0.012, gainValue, 'square', index * 17 - 11);
          playNoise(0.035, gainValue * 0.42, baseFrequency * (2.6 + index * 0.34));
        }, delay);
      });
    };

    const startIdle = () => {
      if (idleStarted || !isReady() || !context || !master) return;

      idleStarted = true;
      idleGain = context.createGain();
      idleGain.gain.value = 0.042 * idleBoost;
      idleGain.connect(master);

      [26, 39, 53].forEach((frequency, index) => {
        const oscillator = context!.createOscillator();
        const filter = context!.createBiquadFilter();
        const gain = context!.createGain();

        oscillator.type = index === 1 ? 'sawtooth' : 'triangle';
        oscillator.frequency.value = frequency;
        oscillator.detune.value = index * 13 - 16;
        filter.type = 'lowpass';
        filter.frequency.value = 145 + index * 72;
        gain.gain.value = (0.26 - index * 0.045) * idleBoost;

        oscillator.connect(filter);
        filter.connect(gain);
        gain.connect(idleGain!);
        oscillator.start();
      });

      const breathSource = context.createBufferSource();
      const breathFilter = context.createBiquadFilter();
      const breathGain = context.createGain();

      breathSource.buffer = getNoise(context);
      breathSource.loop = true;
      breathFilter.type = 'bandpass';
      breathFilter.frequency.value = 310;
      breathFilter.Q.value = 1.15;
      breathGain.gain.value = 0.072 * idleBoost;
      breathSource.connect(breathFilter);
      breathFilter.connect(breathGain);
      breathGain.connect(idleGain);
      breathSource.start();

      playRasp(1.8, 0.042, 64);

      idlePulseTimer = window.setInterval(() => {
        if (currentPhase !== 'ready') return;
        playRasp(0.44 + Math.random() * 0.28, 0.038, 42 + Math.random() * 38);
        if (Math.random() > 0.46) {
          playChitter(520 + Math.random() * 260, 0.018);
        }
      }, 3800);
    };

    const stopIdle = () => {
      if (!context || !idleGain) return;
      idleGain.gain.cancelScheduledValues(context.currentTime);
      idleGain.gain.linearRampToValueAtTime(0.0001, context.currentTime + 0.4);
      if (idlePulseTimer) {
        window.clearInterval(idlePulseTimer);
        idlePulseTimer = null;
      }
    };

    return {
      isRunning: () => isReady(),
      unlock: async (forceFresh = false) => {
        if (forceFresh && context && context.state !== 'running') {
          const staleContext = context;
          context = null;
          master = null;
          idleGain = null;
          idleStarted = false;
          warpPlaying = false;
          noiseBuffer = null;
          if (idlePulseTimer) {
            window.clearInterval(idlePulseTimer);
            idlePulseTimer = null;
          }
          if (staleContext.state !== 'closed') {
            void staleContext.close().catch(() => {});
          }
        }

        const audioContext = getContext();
        if (!audioContext) return false;
        if (audioContext.state !== 'running') {
          try {
            await Promise.race([
              audioContext.resume(),
              new Promise<void>((resolve) => window.setTimeout(resolve, 260))
            ]);
          } catch {
            return false;
          }
        }
        if (audioContext.state === 'running') {
          if (currentPhase === 'ready') startIdle();
          return true;
        }
        return false;
      },
      warp: () => {
        if (!isReady() || warpPlaying || !context || !master) return;

        warpPlaying = true;
        stopIdle();
        const now = context.currentTime;
        const duration = 3.2;
        const low = context.createOscillator();
        const lowGain = context.createGain();
        const pulse = context.createOscillator();
        const pulseGain = context.createGain();

        low.type = 'sawtooth';
        low.frequency.setValueAtTime(42, now);
        low.frequency.exponentialRampToValueAtTime(78, now + 2.15);
        low.frequency.exponentialRampToValueAtTime(34, now + duration);
        lowGain.gain.setValueAtTime(0.0001, now);
        lowGain.gain.exponentialRampToValueAtTime(0.16, now + 0.24);
        lowGain.gain.linearRampToValueAtTime(0.1, now + 2.2);
        lowGain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

        pulse.type = 'triangle';
        pulse.frequency.setValueAtTime(116, now);
        pulse.frequency.exponentialRampToValueAtTime(44, now + duration);
        pulseGain.gain.setValueAtTime(0.0001, now);
        pulseGain.gain.exponentialRampToValueAtTime(0.074, now + 0.16);
        pulseGain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

        low.connect(lowGain);
        pulse.connect(pulseGain);
        lowGain.connect(master);
        pulseGain.connect(master);
        low.start(now);
        pulse.start(now);
        low.stop(now + duration + 0.05);
        pulse.stop(now + duration + 0.05);
        playNoise(duration, 0.13, 900);
        playRasp(duration, 0.11, 52);
        window.setTimeout(() => playRasp(0.62, 0.075, 84), 2140);
        window.setTimeout(() => {
          warpPlaying = false;
        }, duration * 1000);
      },
      arrive: () => {
        playRasp(0.68, 0.13, 46);
        playNoise(0.42, 0.06, 190);
      },
      bootTick: (index: number) => {
        playChitter(300 + index * 55, 0.04);
        playRasp(0.08, 0.024, 86 + index * 9);
      },
      uiHover: () => {
        playChitter(690, 0.018);
      },
      uiSelect: () => {
        playChitter(470, 0.05);
        playRasp(0.12, 0.042, 118);
      },
      vision: () => {
        playRasp(0.22, 0.058, 138);
        playNoise(0.16, 0.045, 2100);
      },
      ready: () => {
        playRasp(0.54, 0.072, 62);
        playChitter(430, 0.028);
        startIdle();
      }
    };
  };

  const xenoAudio = createXenoAudio();
  let xenoAudioUnlocked = false;
  let xenoAudioUnlocking = false;
  let xenoAudioUnlockStarted = 0;
  const audioUnlockEvents = ['pointerdown', 'pointerup', 'touchstart', 'touchend', 'mousedown', 'click', 'keydown'];
  const audioUnlockOptions = { capture: true, passive: true };

  const unlockXenoAudio = (event?: Event) => {
    if (xenoAudioUnlocked && xenoAudio.isRunning()) return;

    const fromGesture = Boolean(event?.isTrusted);
    const now = performance.now();
    if (xenoAudioUnlocking && now - xenoAudioUnlockStarted < 300) return;

    xenoAudioUnlocking = true;
    xenoAudioUnlockStarted = now;
    void xenoAudio.unlock(fromGesture).then((unlocked) => {
      xenoAudioUnlocking = false;
      if (!unlocked) return;

      xenoAudioUnlocked = true;

      if (unlocked && currentPhase === 'jump') {
        xenoAudio.warp();
      }
    }).catch(() => {
      xenoAudioUnlocking = false;
    });
  };

  unlockXenoAudio();
  window.setTimeout(unlockXenoAudio, 250);
  window.addEventListener('pageshow', unlockXenoAudio);
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') unlockXenoAudio();
  });
  audioUnlockEvents.forEach((eventName) => {
    window.addEventListener(eventName, unlockXenoAudio, audioUnlockOptions);
  });

  const normalizeRoute = (route: string) => {
    if (route === '/') return route;
    return route.endsWith('/') ? route : `${route}/`;
  };

  const setSection = (section: string, route?: string, pushState = true, immediate = false) => {
    if (!shell || !viewport) return;

    const previousSection = activeSection;
    const previousPanel = sectionPanels.find((panel) => panel.dataset.sectionPanel === previousSection);
    const nextPanel = sectionPanels.find((panel) => panel.dataset.sectionPanel === section);

    window.clearTimeout(sectionSwitchTimer);
    viewport.classList.remove('is-switching');
    window.setTimeout(() => viewport.classList.add('is-switching'), 0);

    xenoNavButtons.forEach((button) => {
      const isActive = button.dataset.section === section;
      button.classList.toggle('is-active', isActive);
      if (isActive && xenoMenuLabel) xenoMenuLabel.textContent = button.querySelector('.xeno-label')?.textContent ?? 'MENU';
      if (isActive) {
        button.setAttribute('aria-current', 'page');
      } else {
        button.removeAttribute('aria-current');
      }
    });

    const activateNext = () => {
      activeSection = section;
      shell.dataset.currentSection = section;
      viewport.scrollTop = 0;

      sectionPanels.forEach((panel) => {
        const isActive = panel.dataset.sectionPanel === section;
        panel.classList.toggle('is-active', isActive);
        panel.classList.remove('is-exiting');
        panel.classList.toggle('is-entering', isActive);
      });

      window.setTimeout(() => {
        nextPanel?.classList.remove('is-entering');
      }, panelIntroDuration);

      updateScrollDepth();
    };

    if (immediate || previousSection === section || !previousPanel || !nextPanel) {
      activateNext();
    } else {
      previousPanel.classList.add('is-exiting');
      previousPanel.classList.remove('is-entering');
      sectionSwitchTimer = window.setTimeout(activateNext, 420);
    }

    if (route && pushState && normalizeRoute(window.location.pathname) !== normalizeRoute(route)) {
      window.history.pushState({ section }, '', route);
    }
  };

  const setActiveVisionOption = (mode: VisionMode) => {
    visionOptions.forEach((option) => {
      const isActive = option.dataset.visionOption === mode;
      option.classList.toggle('is-active', isActive);
      option.setAttribute('aria-pressed', String(isActive));
      option.removeAttribute('data-sensor-pending');
    });

    if (spectrumLabel) spectrumLabel.textContent = mode.toUpperCase();
  };

  const applyVisionMode = (mode: VisionMode) => {
    if (!shell) return;
    currentVisionMode = mode;
    shell.dataset.visionMode = mode;
    setActiveVisionOption(mode);
    if (mode === 'uv') populateUvSpectrumStars();
  };

  const setVisionMode = (mode: string, immediate = false) => {
    if (!shell) return;
    const nextMode = (['visible', 'uv', 'ir'].includes(mode) ? mode : 'visible') as VisionMode;

    visionModeTimers.forEach((timer) => window.clearTimeout(timer));
    visionModeTimers = [];

    if (immediate) {
      shell.dataset.sensorPhase = 'online';
      applyVisionMode(nextMode);
      return;
    }

    if (nextMode === currentVisionMode) return;

    visionOptions.forEach((option) => {
      const isPending = option.dataset.visionOption === nextMode;
      option.toggleAttribute('data-sensor-pending', isPending);
    });

    shell.dataset.sensorPhase = 'down';
    visionModeTimers.push(window.setTimeout(() => {
      shell.dataset.sensorPhase = 'scan';
    }, 260));
    visionModeTimers.push(window.setTimeout(() => {
      applyVisionMode(nextMode);
      shell.dataset.sensorPhase = 'activate';
    }, 760));
    visionModeTimers.push(window.setTimeout(() => {
      shell.dataset.sensorPhase = 'online';
    }, 1520));
  };

  const setHudHidden = (hidden: boolean) => {
    if (!shell || !hudToggle) return;

    shell.dataset.hudVisibility = hidden ? 'hidden' : 'visible';
    hudToggle.setAttribute('aria-pressed', String(hidden));
    hudToggle.setAttribute('aria-label', hidden ? 'Show HUD' : 'Hide HUD');
    if (hudToggleLabel) hudToggleLabel.textContent = hidden ? 'SHOW HUD' : 'HIDE HUD';
  };

  const setMobileMenuExpanded = (expanded: boolean) => {
    xenoNavbar?.setAttribute('data-expanded', String(expanded));
    xenoMenuToggle?.setAttribute('aria-expanded', String(expanded));
    if (shell) shell.dataset.mobileMenu = expanded ? 'open' : 'closed';
  };

  const updateScrollDepth = () => {
    if (!viewport || !scrollDepth || !scrollPercent) return;
    const maxScroll = Math.max(viewport.scrollHeight - viewport.clientHeight, 1);
    const progress = Math.min(100, Math.max(0, Math.round((viewport.scrollTop / maxScroll) * 100)));
    const scrollDepthHeight = scrollDepth.getBoundingClientRect().height;
    const trackTop = window.matchMedia('(max-width: 760px)').matches ? 0 : 40;
    const trackBottom = window.matchMedia('(max-width: 760px)').matches ? 0 : 24;
    const trackHeight = Math.max(scrollDepthHeight - trackTop - trackBottom, 1);
    const pointerTop = trackTop + trackHeight * (1 - progress / 100);
    scrollDepth.style.setProperty('--scroll-progress', String(progress));
    scrollDepth.style.setProperty('--scroll-progress-percent', `${progress}%`);
    scrollDepth.style.setProperty('--scroll-pointer-top', `${pointerTop}px`);
    scrollPercent.value = `${progress}%`;
    scrollPercent.textContent = `${progress}%`;

    const activeCount = Math.ceil((progress / 100) * 13);
    scrollDepth.querySelectorAll<HTMLElement>('.depth-arc i').forEach((segment, index) => {
      segment.dataset.active = index < activeCount ? 'true' : 'false';
    });

    scrollDepth.querySelectorAll<HTMLElement>('[data-depth-mark]').forEach((mark) => {
      const threshold = Number(mark.dataset.depthMark ?? 0);
      mark.dataset.active = progress >= threshold ? 'true' : 'false';
    });
  };

  const setPhase = (phase: CockpitPhase) => {
    if (!shell) return;
    const phaseChanged = currentPhase !== phase;
    currentPhase = phase;
    shell.dataset.phase = phase;

    if (!phaseChanged && phase !== 'jump') return;

    if (phase === 'jump') {
      xenoAudio.warp();
    } else if (phase === 'arrived') {
      xenoAudio.arrive();
    } else if (phase === 'boot') {
      [1, 2, 3, 4, 5, 6].forEach((order) => {
        window.setTimeout(() => xenoAudio.bootTick(order), order * 115);
      });
    } else if (phase === 'ready') {
      xenoAudio.ready();
      const activePanel = sectionPanels.find((panel) => panel.classList.contains('is-active'));
      activePanel?.classList.add('is-entering');
      window.setTimeout(() => {
        activePanel?.classList.remove('is-entering');
      }, panelIntroDuration);
    }
  };

  const setRevealPhase = (phase: RevealPhase) => {
    if (!shell) return;
    shell.dataset.revealPhase = phase;
  };

  const runHyperspaceJump = () => {
    if (!hyperspaceCanvas) return;

    const context = hyperspaceCanvas.getContext('2d');
    if (!context) return;

    const jumpDuration = lowPowerMedia.matches ? 1280 : 1700;
    const decelStart = lowPowerMedia.matches ? 720 : 980;
    const dpr = Math.min(window.devicePixelRatio || 1, lowPowerMedia.matches ? 1.15 : 1.35);
    const width = window.innerWidth;
    const height = window.innerHeight;
    const centerX = width / 2;
    const centerY = height / 2;
    const focalLength = Math.min(width, height) * 0.72;
    const starCount = width < 760 ? 110 : 210;
    const calmStarCount = width < 760 ? 24 : 48;
    const colors = [
      [255, 255, 255],
      [197, 239, 247],
      [118, 214, 255],
      [42, 180, 254],
      [165, 210, 255]
    ];

    hyperspaceCanvas.width = Math.floor(width * dpr);
    hyperspaceCanvas.height = Math.floor(height * dpr);
    hyperspaceCanvas.style.width = `${width}px`;
    hyperspaceCanvas.style.height = `${height}px`;
    context.setTransform(dpr, 0, 0, dpr, 0, 0);
    context.lineCap = 'round';

    const resetStar = (star?: {
      x: number;
      y: number;
      z: number;
      previousX: number;
      previousY: number;
      alpha: number;
      size: number;
      color: number[];
    }) => {
      const next = star ?? {
        x: 0,
        y: 0,
        z: 0,
        previousX: centerX,
        previousY: centerY,
        alpha: 1,
        size: 1,
        color: colors[0]
      };
      next.x = (Math.random() - 0.5) * width * 1.28;
      next.y = (Math.random() - 0.5) * height * 1.28;
      next.z = Math.random() * 0.92 + 0.08;
      next.alpha = 0.34 + Math.random() * 0.66;
      next.size = 0.6 + Math.random() * 1.3;
      next.color = colors[Math.floor(Math.random() * colors.length)];
      const projected = project(next);
      next.previousX = projected.x;
      next.previousY = projected.y;
      return next;
    };

    const project = (star: { x: number; y: number; z: number }) => {
      const scale = focalLength / Math.max(star.z * focalLength, 1);
      return {
        x: centerX + star.x * scale,
        y: centerY + star.y * scale
      };
    };

    const stars = Array.from({ length: starCount }, () => resetStar());
    const calmStars = Array.from({ length: calmStarCount }, () => ({
      x: Math.random() * width,
      y: Math.random() * height,
      alpha: 0.25 + Math.random() * 0.55,
      size: Math.random() < 0.82 ? 1 : 1.4,
      speed: 4 + Math.random() * 12,
      driftX: (Math.random() - 0.5) * 1.6,
      driftY: (Math.random() - 0.5) * 1.6,
      twinkle: Math.random() * Math.PI * 2
    }));
    const start = performance.now();
    let frame = 0;
    let calmFrame = 0;
    let calmStarted = false;
    let lastCalmTime = start;

    const resetCalmStar = (star: (typeof calmStars)[number]) => {
      const angle = Math.random() * Math.PI * 2;
      const horizontalEdge = Math.random() > 0.5;
      const edgeOffset = 8 + Math.random() * 18;
      star.x = horizontalEdge ? Math.random() * width : (Math.cos(angle) > 0 ? -edgeOffset : width + edgeOffset);
      star.y = horizontalEdge ? (Math.sin(angle) > 0 ? -edgeOffset : height + edgeOffset) : Math.random() * height;
      star.alpha = 0.18 + Math.random() * 0.48;
      star.size = Math.random() < 0.84 ? 1 : 1.35;
      star.speed = 3 + Math.random() * 10;
      star.driftX = (Math.random() - 0.5) * 1.4;
      star.driftY = (Math.random() - 0.5) * 1.4;
      star.twinkle = Math.random() * Math.PI * 2;
    };

    const syncCalmStarsFromJump = () => {
      const projectedStars = stars
        .map((star) => project(star))
        .filter((star) => star.x >= 0 && star.x <= width && star.y >= 0 && star.y <= height);

      calmStars.forEach((star, index) => {
        const source = projectedStars[index % Math.max(projectedStars.length, 1)];

        if (source) {
          star.x = source.x;
          star.y = source.y;
        } else {
          resetCalmStar(star);
        }

        star.alpha = 0.22 + Math.random() * 0.44;
        star.size = Math.random() < 0.86 ? 1 : 1.32;
        star.speed = 1.5 + Math.random() * 4.2;
        star.driftX = (Math.random() - 0.5) * 0.7;
        star.driftY = (Math.random() - 0.5) * 0.7;
        star.twinkle = Math.random() * Math.PI * 2;
      });
    };

    const renderCalmSpace = (time = performance.now(), shouldMove = false) => {
      const delta = Math.min((time - lastCalmTime) / 1000, 0.05);
      lastCalmTime = time;

      context.clearRect(0, 0, width, height);
      context.fillStyle = 'rgb(0, 3, 8)';
      context.fillRect(0, 0, width, height);

      calmStars.forEach((star) => {
        if (shouldMove) {
          const dx = star.x - centerX;
          const dy = star.y - centerY;
          const distance = Math.max(Math.hypot(dx, dy), 1);
          star.x += (dx / distance) * star.speed * delta + star.driftX * delta;
          star.y += (dy / distance) * star.speed * delta + star.driftY * delta;

          if (
            star.x < -24 ||
            star.x > width + 24 ||
            star.y < -24 ||
            star.y > height + 24
          ) {
            resetCalmStar(star);
          }
        }

        const pulse = 0.72 + Math.sin(time * 0.0007 + star.twinkle) * 0.18;
        context.fillStyle = `rgba(210, 248, 255, ${star.alpha * pulse})`;
        context.fillRect(star.x, star.y, star.size, star.size);
      });
    };

    const startCalmSpace = () => {
      if (calmStarted) return;
      calmStarted = true;
      syncCalmStarsFromJump();
      lastCalmTime = performance.now();

      const drift = (time: number) => {
        renderCalmSpace(time, true);
        if (document.visibilityState === 'visible' && !lowPowerMedia.matches) {
          calmFrame = window.requestAnimationFrame(drift);
        }
      };

      if (lowPowerMedia.matches) {
        renderCalmSpace(performance.now(), false);
      } else {
        calmFrame = window.requestAnimationFrame(drift);
      }
    };

    const draw = (time: number) => {
      const elapsed = time - start;
      const progress = Math.min(elapsed / jumpDuration, 1);
      const decelProgress = elapsed < decelStart ? 0 : Math.min((elapsed - decelStart) / (jumpDuration - decelStart), 1);
      const easeOut = 1 - Math.pow(1 - decelProgress, 3);
      const speed = 0.042 - easeOut * 0.035;
      const lineScale = 1 - easeOut * 0.72;
      const fade = 1 - easeOut * 0.22;

      context.clearRect(0, 0, width, height);
      context.fillStyle = `rgba(0, 4, 12, ${0.86 - easeOut * 0.18})`;
      context.fillRect(0, 0, width, height);

      stars.forEach((star) => {
        star.previousX = project(star).x;
        star.previousY = project(star).y;
        star.z -= speed;

        if (star.z <= 0.018) {
          resetStar(star);
          return;
        }

        const current = project(star);
        if (
          current.x < -width * 0.15 ||
          current.x > width * 1.15 ||
          current.y < -height * 0.15 ||
          current.y > height * 1.15
        ) {
          resetStar(star);
          return;
        }

        const [r, g, b] = star.color;

        context.beginPath();
        context.moveTo(star.previousX, star.previousY);
        context.lineTo(
          star.previousX + (current.x - star.previousX) * Math.max(lineScale, 0.12),
          star.previousY + (current.y - star.previousY) * Math.max(lineScale, 0.12)
        );
        context.lineWidth = star.size * (1.65 - easeOut * 0.85);
        context.strokeStyle = `rgba(${r}, ${g}, ${b}, ${star.alpha * fade})`;
        context.stroke();
      });

      if (progress < 1) {
        frame = window.requestAnimationFrame(draw);
      } else {
        startCalmSpace();
      }
    };

    frame = window.requestAnimationFrame(draw);
    window.setTimeout(() => {
      window.cancelAnimationFrame(frame);
      if (!calmStarted) startCalmSpace();
    }, jumpDuration + 80);
  };

  const bootCockpit = () => {
    if (!shell) return;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduceMotion) {
      setPhase('ready');
      return;
    }

    const jumpDuration = lowPowerMedia.matches ? 1280 : 1700;
    const arrivedHold = lowPowerMedia.matches ? 120 : 180;
    const bootDuration = lowPowerMedia.matches ? 420 : 500;

    setPhase('jump');
    setRevealPhase('dark');
    runHyperspaceJump();
    window.setTimeout(() => {
      setRevealPhase('wake');
    }, 30);
    window.setTimeout(() => {
      setRevealPhase('awake');
    }, 120);
    window.setTimeout(() => {
      setRevealPhase('charge');
    }, 260);
    window.setTimeout(() => {
      setRevealPhase('settled');
      setPhase('arrived');
    }, jumpDuration);
    window.setTimeout(() => {
      setPhase('boot');
    }, jumpDuration + arrivedHold);
    window.setTimeout(() => {
      setPhase('ready');
    }, jumpDuration + arrivedHold + bootDuration);
  };

  xenoNavButtons.forEach((button) => {
    button.addEventListener('pointerenter', () => {
      xenoAudio.uiHover();
    });

    button.addEventListener('pointermove', (event) => {
      const rect = button.getBoundingClientRect();
      button.style.setProperty('--cursor-x', `${event.clientX - rect.left}px`);
      button.style.setProperty('--cursor-y', `${event.clientY - rect.top}px`);
    });

    button.addEventListener('click', (event) => {
      const section = button.dataset.section;
      const route = button.dataset.route;
      if (!section || !route || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

      event.preventDefault();
      xenoAudio.uiSelect();
      setMobileMenuExpanded(false);
      setSection(section, route);
    });
  });

  xenoMenuToggle?.addEventListener('click', () => {
    const isExpanded = xenoNavbar?.dataset.expanded === 'true';
    setMobileMenuExpanded(!isExpanded);
    xenoAudio.uiSelect();
  });

  visionOptions.forEach((option) => {
    option.addEventListener('pointerenter', () => {
      xenoAudio.uiHover();
    });

    option.addEventListener('click', () => {
      xenoAudio.vision();
      setVisionMode(option.dataset.visionOption ?? 'visible');
      window.clearTimeout(spectrumCollapseTimer);
      visionSwitch?.removeAttribute('data-expanded');
      spectrumToggle?.setAttribute('aria-expanded', 'false');
    });
  });

  spectrumToggle?.addEventListener('click', () => {
    const isExpanded = visionSwitch?.dataset.expanded === 'true';
    window.clearTimeout(spectrumCollapseTimer);
    visionSwitch?.toggleAttribute('data-expanded', !isExpanded);
    if (visionSwitch) visionSwitch.dataset.expanded = String(!isExpanded);
    spectrumToggle.setAttribute('aria-expanded', String(!isExpanded));
    xenoAudio.uiSelect();

    if (!isExpanded) {
      spectrumCollapseTimer = window.setTimeout(() => {
        visionSwitch?.removeAttribute('data-expanded');
        spectrumToggle.setAttribute('aria-expanded', 'false');
      }, 2000);
    }
  });

  hudToggle?.addEventListener('pointerenter', () => {
    xenoAudio.uiHover();
  });

  hudToggle?.addEventListener('click', () => {
    const isHidden = shell?.dataset.hudVisibility === 'hidden';
    xenoAudio.uiSelect();
    setHudHidden(!isHidden);
  });

  travelToggle?.addEventListener('pointerenter', () => {
    xenoAudio.uiHover();
  });

  travelToggle?.addEventListener('click', () => {
    if (!travelWidget || !travelToggle) return;

    window.clearTimeout(travelCollapseTimer);
    travelWidget.dataset.expanded = 'true';
    travelToggle.setAttribute('aria-expanded', 'true');
    xenoAudio.uiSelect();

    travelCollapseTimer = window.setTimeout(() => {
      travelWidget.dataset.expanded = 'false';
      travelToggle.setAttribute('aria-expanded', 'false');
    }, 2000);
  });

  viewport?.addEventListener('scroll', updateScrollDepth, { passive: true });
  window.addEventListener('popstate', () => {
    const matchingButton = xenoNavButtons.find((button) => normalizeRoute(button.dataset.route ?? '') === normalizeRoute(window.location.pathname));
    setSection(matchingButton?.dataset.section ?? 'home', undefined, false, true);
  });

  window.addEventListener('resize', () => {
    if (!mobileMedia.matches) setMobileMenuExpanded(false);
    updateScrollDepth();
  }, { passive: true });

  const shouldForceFirstBootHome = (() => {
    try {
      const bootKey = 'cockpit:first-boot-complete';
      const hasBooted = window.sessionStorage.getItem(bootKey) === 'true';
      window.sessionStorage.setItem(bootKey, 'true');
      return !hasBooted && normalizeRoute(window.location.pathname) !== '/';
    } catch {
      return false;
    }
  })();

  if (shouldForceFirstBootHome) {
    window.history.replaceState({ section: 'home' }, '', '/');
  }

  initializeSpectrumSpace();
  setSection(shouldForceFirstBootHome ? 'home' : shell?.dataset.currentSection ?? 'home', undefined, false, true);
  setVisionMode('visible', true);
  setHudHidden(false);
  updateScrollDepth();
  bootCockpit();
</script>

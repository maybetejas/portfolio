<aside class="vision-system hud-boot-item" data-boot-order="2" aria-label="Ship sensor controls">
  <div class="vision-switch" aria-label="Spectrum mode">
    <span class="stats-corner stats-corner--tl" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--tr" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--bl" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--br" aria-hidden="true"><i></i></span>
    <span class="stats-opener" aria-hidden="true"></span>
    <span class="vision-divider" aria-hidden="true"></span>

    <button class="spectrum-toggle" type="button" data-spectrum-toggle aria-expanded="false">
      <span data-spectrum-label>VISIBLE</span>
      <i aria-hidden="true"></i>
    </button>

    <button class="vision-option is-active" type="button" data-vision-option="visible" aria-pressed="true">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3.5 12s3.1-5.2 8.5-5.2S20.5 12 20.5 12 17.4 17.2 12 17.2 3.5 12 3.5 12Z" />
        <circle cx="12" cy="12" r="2.2" />
      </svg>
      <span>VISIBLE</span>
    </button>
    <button class="vision-option" type="button" data-vision-option="uv" aria-pressed="false">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 3.5v3" /><path d="M12 17.5v3" /><path d="M4.6 12h3" /><path d="M16.4 12h3" />
        <path d="m6.8 6.8 2.1 2.1" /><path d="m15.1 15.1 2.1 2.1" />
        <path d="m17.2 6.8-2.1 2.1" /><path d="m8.9 15.1-2.1 2.1" />
        <circle cx="12" cy="12" r="2.4" />
      </svg>
      <span>UV</span>
    </button>
    <button class="vision-option" type="button" data-vision-option="ir" aria-pressed="false">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="7.2" /><circle cx="12" cy="12" r="3.5" /><circle cx="12" cy="12" r="1.1" />
      </svg>
      <span>IR</span>
    </button>
  </div>

  <button class="hud-toggle" type="button" data-hud-toggle aria-pressed="false" aria-label="Hide HUD">
    <span class="stats-corner stats-corner--tl" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--tr" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--bl" aria-hidden="true"><i></i></span>
    <span class="stats-corner stats-corner--br" aria-hidden="true"><i></i></span>
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4 7.5h16" /><path d="M4 16.5h16" />
      <path d="M7.5 4v16" /><path d="M16.5 4v16" />
    </svg>
    <span data-hud-toggle-label>HIDE HUD</span>
  </button>
</aside>

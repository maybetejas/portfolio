<aside class="system-stats hud-boot-item" data-boot-order="1" aria-label="System status">
  <div class="stat-row">
    <span class="stat-glyph" aria-hidden="true"></span>
    <span class="stat-name">SYSTEM</span>
    <strong>ONLINE</strong>
  </div>
  <div class="stat-row">
    <span class="stat-glyph stat-glyph--comms" aria-hidden="true"></span>
    <span class="stat-name">COMMS</span>
    <strong>AVAILABLE</strong>
  </div>
  <div class="stat-row stat-row--signal">
    <span class="stat-glyph stat-glyph--signal" aria-hidden="true"></span>
    <span class="stat-name">SIGNAL</span>
    <span class="signal-bars" aria-hidden="true">
      <i></i><i></i><i></i><i></i><i></i><i></i><i></i>
    </span>
  </div>
  <div class="stat-row">
    <span class="stat-glyph stat-glyph--power" aria-hidden="true"></span>
    <span class="stat-name">POWER</span>
    <strong>100%</strong>
    <span class="power-line" aria-hidden="true"></span>
  </div>
</aside>

<aside class="system-stats hud-boot-item" data-system-stats data-expanded="false" data-boot-order="1" aria-label="Operator status">
  <span class="stats-corner stats-corner--tl" aria-hidden="true"><i></i></span>
  <span class="stats-corner stats-corner--tr" aria-hidden="true"><i></i></span>
  <span class="stats-corner stats-corner--bl" aria-hidden="true"><i></i></span>
  <span class="stats-corner stats-corner--br" aria-hidden="true"><i></i></span>
  <span class="stats-opener" aria-hidden="true"></span>
  <span class="stats-divider" aria-hidden="true"></span>
  <button class="stats-toggle" type="button" data-stats-toggle aria-expanded="false">STATS</button>

  <div class="stat-row">
    <span class="stat-glyph stat-glyph--status" aria-hidden="true"></span>
    <span class="stat-name">STATUS</span>
    <strong>AVAILABLE</strong>
  </div>
  <div class="stat-row">
    <span class="stat-glyph stat-glyph--deploy" aria-hidden="true"></span>
    <span class="stat-name">EXPERIENCE</span>
    <strong>3+ YEARS</strong>
  </div>
  <div class="stat-row">
    <span class="stat-glyph stat-glyph--client" aria-hidden="true"></span>
    <span class="stat-name">LOCATION</span>
    <strong>PUNE, INDIA</strong>
  </div>
  <div class="stat-row">
    <span class="stat-glyph stat-glyph--repos" aria-hidden="true"></span>
    <span class="stat-name">TIMEZONE</span>
    <strong>GMT +5:30</strong>
  </div>
</aside>

<script>
  const systemStats = document.querySelector<HTMLElement>('[data-system-stats]');
  const statsToggle = systemStats?.querySelector<HTMLButtonElement>('[data-stats-toggle]');
  let statsCollapseTimer = 0;

  statsToggle?.addEventListener('click', () => {
    if (!systemStats) return;

    const isExpanded = systemStats.dataset.expanded === 'true';
    systemStats.dataset.expanded = String(!isExpanded);
    systemStats.dataset.opening = 'true';
    statsToggle.setAttribute('aria-expanded', String(!isExpanded));
    window.clearTimeout(statsCollapseTimer);

    window.setTimeout(() => {
      systemStats.removeAttribute('data-opening');
    }, 900);

    if (!isExpanded) {
      statsCollapseTimer = window.setTimeout(() => {
        systemStats.dataset.expanded = 'false';
        statsToggle.setAttribute('aria-expanded', 'false');
      }, 2000);
    }
  });
</script>

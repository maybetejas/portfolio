    responsibilities: ['Product Strategy', 'Market Research', 'User Research', 'Brand Identity', 'UI / UX Design', 'Frontend Development', 'Backend Development', 'Database Design', 'Operations', 'Marketing', 'Customer Support', 'Analytics', 'Product Iteration'],
    challenges: ['Designing a booking flow that felt simple while supporting real operational constraints.', 'Creating internal tools for washers and admin workflows without overbuilding the first version.', 'Balancing engineering, customer acquisition, service quality, and business operations at launch.'],
    learnings: ['A product only becomes useful when software, operations, and customer feedback work together.', 'Founder-led engineering needs fast validation, clear workflows, and constant iteration over perfect initial scope.'],
    links: [
      { label: 'Visit Website', href: 'https://washywashy.in/' },
      { label: 'Instagram', href: 'https://www.instagram.com/washywashyy/' }

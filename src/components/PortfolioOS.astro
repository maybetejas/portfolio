      { label: 'Orders Completed', value: 100, suffix: '+' },
      { label: 'Organic Users', value: 200, suffix: '+' },
      { label: 'Revenue Generated', value: 30000, prefix: '₹', suffix: '+' }
    ],
    timeline: '2024 - Present',
    story: [
      'Washy Washy is a doorstep car wash startup that brings trained washers directly to customers at homes and offices.',
      'I started by researching the traditional car wash market, interviewing potential users, studying local competitors, and identifying gaps around convenience, pricing, trust, and water efficiency.',
      'The product model lets customers book online while independent washers receive and manage jobs through an internal dashboard.',
      'I handled the complete journey from product strategy and branding to UI/UX, full-stack development, operations, marketing, customer support, launch, and iteration based on real customer feedback.'
    ],
    screenshots: [
      { src: '/assets/washywashylandingpagemobile.avif', label: 'Customer mobile booking entry', type: 'mobile' },
      { src: '/assets/washywashyslotbookingpage.avif', label: 'Slot booking flow', type: 'mobile' }

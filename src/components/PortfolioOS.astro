<script>
  const projectMap = document.querySelector<HTMLElement>('[data-project-map]');
  const projectOpenButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-project-open]'));
  const projectBackButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-project-back]'));
  const projectDossiers = Array.from(document.querySelectorAll<HTMLElement>('[data-project-dossier]'));
  const labMap = document.querySelector<HTMLElement>('[data-lab-map]');
  const labOpenButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-lab-open]'));
  const labBackButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-lab-back]'));
  const labDetails = Array.from(document.querySelectorAll<HTMLElement>('[data-lab-detail]'));
  const skillMap = document.querySelector<HTMLElement>('[data-skill-map]');
  const skillModules = Array.from(document.querySelectorAll<HTMLElement>('[data-skill-module]'));
  const skillTriggers = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-skill-trigger]'));
  const skillMobileMedia = window.matchMedia('(max-width: 760px)');
  let skillCollapseTimer = 0;

  const formatMetric = (value: number, prefix: string, suffix: string) => {
    const formatted = value >= 1000 ? value.toLocaleString('en-IN') : String(value);
    return `${prefix}${formatted}${suffix}`;
  };

  const animateMetric = (metric: HTMLElement) => {
    const target = Number(metric.dataset.countTarget ?? '0');
    const prefix = metric.dataset.countPrefix ?? '';
    const suffix = metric.dataset.countSuffix ?? '';
    const duration = 860;
    const start = performance.now();

    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(target * eased);

      metric.textContent = formatMetric(current, prefix, suffix);

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        metric.textContent = formatMetric(target, prefix, suffix);
      }
    };

    metric.textContent = formatMetric(0, prefix, suffix);
    requestAnimationFrame(tick);
  };

  const setProjectDossier = (projectId?: string) => {
    if (!projectMap) return;

    projectMap.dataset.projectState = projectId ? 'detail' : 'list';

    projectDossiers.forEach((dossier) => {
      const isActive = Boolean(projectId && dossier.dataset.projectDossier === projectId);
      dossier.classList.toggle('is-active', isActive);
      dossier.setAttribute('aria-hidden', String(!isActive));

      if (isActive) {
        dossier.querySelectorAll<HTMLElement>('[data-count-target]').forEach(animateMetric);
      }
    });

    if (projectId) {
      projectMap.closest<HTMLElement>('.content-viewport')?.scrollTo({ top: 0, behavior: 'smooth' });
    }
  };

  projectOpenButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const projectId = button.dataset.projectOpen;
      if (!projectId) return;
      setProjectDossier(projectId);
    });
  });

  projectBackButtons.forEach((button) => {
    button.addEventListener('click', () => setProjectDossier());
  });

  const setLabDetail = (labId?: string) => {
    if (!labMap) return;

    labMap.dataset.labState = labId ? 'detail' : 'list';

    labDetails.forEach((detail) => {
      const isActive = Boolean(labId && detail.dataset.labDetail === labId);
      detail.classList.toggle('is-active', isActive);
      detail.setAttribute('aria-hidden', String(!isActive));
    });

    if (labId) {
      const activeDetail = labDetails.find((detail) => detail.dataset.labDetail === labId);
      activeDetail?.querySelectorAll<HTMLElement>('[data-lab-number], [data-lab-range]').forEach(animateLabMetric);
      labMap.closest<HTMLElement>('.content-viewport')?.scrollTo({ top: 0, behavior: 'smooth' });
    }
  };

  const animateLabMetric = (metric: HTMLElement) => {
    const duration = 860;
    const start = performance.now();
    const prefix = metric.dataset.labPrefix ?? '';
    const suffix = metric.dataset.labSuffix ?? '';
    const decimals = Number(metric.dataset.labDecimals ?? '0');
    const target = Number(metric.dataset.labTarget ?? '0');
    const low = Number(metric.dataset.labRangeLow ?? '0');
    const high = Number(metric.dataset.labRangeHigh ?? '0');
    const isRange = metric.hasAttribute('data-lab-range');

    const formatNumber = (value: number) => value.toFixed(decimals);

    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);

      if (isRange) {
        metric.textContent = `${Math.round(low * eased)}-${Math.round(high * eased)}${suffix}`;
      } else {
        metric.textContent = `${prefix}${formatNumber(target * eased)}${suffix}`;
      }

      if (progress < 1) requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  };

  labOpenButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const labId = button.dataset.labOpen;
      if (!labId) return;
      setLabDetail(labId);
    });
  });

  labBackButtons.forEach((button) => {
    button.addEventListener('click', () => setLabDetail());
  });

  window.addEventListener('portfolio-section-change', (event) => {
    const section = (event as CustomEvent<{ section?: string }>).detail?.section;
    if (section !== 'projects') setProjectDossier();
    if (section !== 'lab') setLabDetail();
    if (section !== 'blog' && blogMap) blogMap.dataset.readerOpen = 'false';
  });

  window.addEventListener('pageshow', () => {
    setProjectDossier();
    setLabDetail();
  });

  const setActiveSkillModule = (module?: HTMLElement) => {
    window.clearTimeout(skillCollapseTimer);

    skillModules.forEach((item) => {
      const isActive = Boolean(module && item === module);
      item.classList.toggle('is-active', isActive);
      item.classList.toggle('is-dimmed', Boolean(module && item !== module));
      item.querySelector<HTMLButtonElement>('[data-skill-trigger]')?.setAttribute('aria-expanded', String(isActive));
      item.querySelector<HTMLElement>('.skill-system-capabilities')?.setAttribute('aria-hidden', String(!isActive));
    });

    if (skillMap) {
      skillMap.dataset.skillActive = module?.dataset.skillModule ?? '';
    }

    if (module && skillMobileMedia.matches) {
      skillCollapseTimer = window.setTimeout(() => setActiveSkillModule(), 2000);
    }
  };

  skillTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const module = trigger.closest<HTMLElement>('[data-skill-module]');
      if (!module) return;
      setActiveSkillModule(module.classList.contains('is-active') ? undefined : module);
    });
  });

  const blogMap = document.querySelector<HTMLElement>('[data-blog-map]');
  const blogOpenButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-blog-open]'));
  const blogCloseButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-blog-close]'));
  const blogReaders = Array.from(document.querySelectorAll<HTMLElement>('[data-blog-reader]'));

  blogOpenButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const postId = button.dataset.blogOpen;
      if (!postId || !blogMap) return;

      blogMap.dataset.readerOpen = 'true';
      blogReaders.forEach((reader) => {
        reader.classList.toggle('is-active', reader.dataset.blogReader === postId);
      });
    });
  });

  blogCloseButtons.forEach((button) => {
    button.addEventListener('click', () => {
      if (blogMap) blogMap.dataset.readerOpen = 'false';
    });
  });
</script>

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const renderedPosts = await Promise.all(
  posts.map(async (post) => {
    const { Content } = await render(post);
    return { ...post, Content };
  })
);
---

<div class="os-system" data-os-system>
  <section class="os-panel os-panel--home is-active" data-section-panel="home" data-os-panel="home">
    <HomeBioScan />
  </section>

  <section class="os-panel os-panel--projects" data-section-panel="projects" data-os-panel="projects">
    <h1 class="os-title">PROJECTS</h1>
    <svg class="os-connectors os-connectors--projects" viewBox="0 0 760 460" preserveAspectRatio="none" aria-hidden="true">
      <path pathLength="1" d="M180 84 H282 L316 118 H372" />
      <path pathLength="1" d="M460 248 H520 L552 292 H610" />
      <path pathLength="1" d="M342 332 H288 L258 374 H196" />
    </svg>
    <div class="project-map project-mission-system" data-project-map data-project-state="list">
      <div class="project-list" data-project-list>
        {projects.map((project, index) => (
          <article class="os-card project-card project-card--mission" style={`--project-cover: url('${project.cover}'); --os-delay: ${380 + index * 160}ms`}>
            <span class="stats-opener os-opener" aria-hidden="true"></span>
            {corners.map((corner) => <span class={`stats-corner stats-corner--${corner} os-corner`} aria-hidden="true"><i></i></span>)}
            <button class="project-card-trigger" type="button" data-project-open={project.id} aria-label={`Open ${project.title} project details`}>
              <span class="project-card-wallpaper" aria-hidden="true"></span>
              <span class="project-card-content">
                <span class="os-kicker">{project.subtitle}</span>
                <strong>{project.title}</strong>
                <span>{project.description}</span>
                <span class="project-status">{project.status}</span>
                <span class="os-tags">
                  {project.tech.map((tag) => <span>{tag}</span>)}
                </span>
                <span class="os-action project-card-action">OPEN PROJECT</span>
              </span>
            </button>
          </article>
        ))}
      </div>

      <div class="project-dossiers" data-project-dossiers>
        {projects.map((project) => (
          <article class="project-dossier" data-project-dossier={project.id} aria-hidden="true">
            <button class="project-back" type="button" data-project-back>
              <span aria-hidden="true">&lt;</span>
              BACK
            </button>

            <section class="project-dossier-hero" style={`--project-hero: url('${project.hero}');`}>
              <span class="stats-opener os-opener" aria-hidden="true"></span>
              {corners.map((corner) => <span class={`stats-corner stats-corner--${corner} os-corner`} aria-hidden="true"><i></i></span>)}
              <div class="project-hero-copy">
                <p class="os-kicker">{project.status}</p>
                <h2>{project.title}</h2>
                <p>{project.oneLine}</p>
                <div class="project-cta-row">
                  {project.links.map((link) => (
                    <a class="os-action project-link" href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined}>{link.label}</a>
                  ))}
                </div>
              </div>
              <div class="project-metrics" aria-label={`${project.title} metrics`}>
                {project.metrics.map((metric) => (
                  <div class="project-metric">
                    <strong data-count-target={metric.value} data-count-prefix={metric.prefix ?? ''} data-count-suffix={metric.suffix ?? ''}>0{metric.suffix ?? ''}</strong>
                    <span>{metric.label}</span>
                  </div>
                ))}
              </div>
            </section>

            <section class="project-dossier-section project-story">
              <p class="os-kicker">Project Story</p>
              <div>
                {project.story.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </section>

            <section class="project-dossier-grid">
              <div class="project-dossier-section">
                <p class="os-kicker">Timeline</p>
                <strong class="project-timeline">{project.timeline}</strong>
              </div>
              <div class="project-dossier-section">
                <p class="os-kicker">Technologies</p>
                <div class="os-tags project-chip-list">
                  {project.tech.map((tag) => <span>{tag}</span>)}
                </div>
              </div>
            </section>

            <section class="project-screenshot-gallery" aria-label={`${project.title} screenshots`}>
              {project.screenshots.map((shot) => (
                <figure class:list={['project-shot', `project-shot--${shot.type}`]}>
                  <img src={shot.src} alt={shot.label} loading="lazy" />
                  <figcaption>{shot.label}</figcaption>
                </figure>
              ))}
            </section>

            <section class="project-dossier-section">
              <p class="os-kicker">Responsibilities</p>
              <div class="project-responsibility-grid">
                {project.responsibilities.map((item) => <span>{item}</span>)}
              </div>
            </section>

            <section class="project-dossier-grid">
              <div class="project-dossier-section">
                <p class="os-kicker">Challenges</p>
                <ul>
                  {project.challenges.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <div class="project-dossier-section">
                <p class="os-kicker">What I Learned</p>
                <ul>
                  {project.learnings.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            </section>

          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="os-panel os-panel--lab" data-section-panel="lab" data-os-panel="lab">
    <h1 class="os-title">LAB</h1>
    <svg class="os-connectors os-connectors--lab" viewBox="0 0 760 460" preserveAspectRatio="none" aria-hidden="true">
      <path pathLength="1" d="M150 112 H274 L318 156 H404" />
      <path pathLength="1" d="M420 244 H542 L604 298" />
      <path pathLength="1" d="M316 336 H246 L196 388" />
    </svg>
    <div class="lab-map" data-lab-map data-lab-state="list">
      <div class="lab-list" data-lab-list>
        {labItems.map((item, index) => (
          <article class="os-card lab-card" data-lab-card style={`--os-delay: ${380 + index * 130}ms; --lab-progress: ${item.progress}%`}>
            <span class="stats-opener os-opener" aria-hidden="true"></span>
            {corners.map((corner) => <span class={`stats-corner stats-corner--${corner} os-corner`} aria-hidden="true"><i></i></span>)}
            <button class="lab-card-trigger" type="button" data-lab-open={item.id} aria-label={`Open ${item.title} lab details`}>
              <span class="lab-visual" aria-hidden="true">
                <img src={item.image} alt="" loading="lazy" decoding="async" />
                <span class="lab-visual-scan"></span>
              </span>
              <span class="lab-card-body">
                <strong>{item.title}</strong>
                <span class="lab-summary">{item.summary}</span>
                <span class="lab-stage-line">Stage: <b>{item.stage}</b></span>
                <span class="lab-progress-label">Progress: <b>{item.progress}%</b></span>
                <span class="lab-progress" aria-label={`${item.progress}% planning progress`}>
                  <span></span>
                </span>
                <span class="os-action lab-card-action">OPEN LAB FILE</span>
              </span>
            </button>
          </article>
        ))}
      </div>

      <div class="lab-dossiers" data-lab-dossiers>
        {labItems.map((item) => (
          <article class="lab-dossier" data-lab-detail={item.id} aria-hidden="true" style={`--lab-progress: ${item.progress}%`}>
            <button class="project-back lab-back" type="button" data-lab-back>
              <span aria-hidden="true">&lt;</span>
              BACK
            </button>

            <section class="lab-dossier-hero">
              <span class="stats-opener os-opener" aria-hidden="true"></span>
              {corners.map((corner) => <span class={`stats-corner stats-corner--${corner} os-corner`} aria-hidden="true"><i></i></span>)}
              <div class="lab-metric-grid" aria-label={`${item.title} opportunity metrics`}>
                <div class="lab-metric">
                  <span>Market Opportunity</span>
                  <strong data-lab-number data-lab-prefix="$" data-lab-target={item.market.tam} data-lab-decimals="1" data-lab-suffix="B">$0.0B</strong>
                  <small>Global Total Addressable Market</small>
                </div>
                <div class="lab-metric lab-metric--wide">
                  <span>Potential Users</span>
                  <strong data-lab-range data-lab-range-low={item.market.usersLow} data-lab-range-high={item.market.usersHigh} data-lab-suffix="M">0-0M</strong>
                  <small>Approximately 80-160 million people globally.</small>
                </div>
                <div class="lab-metric">
                  <span>Competitors Researched</span>
                  <strong data-lab-number data-lab-target={item.market.competitors} data-lab-suffix="+">0+</strong>
                  <small>Market scan complete enough to shape the product direction.</small>
                </div>
              </div>
            </section>

            <section class="lab-stage-grid">
              <div class="project-dossier-section lab-dossier-section">
                <p class="os-kicker">Stage</p>
                <span class="lab-stage-badge">{item.stage}</span>
              </div>
              <div class="project-dossier-section lab-dossier-section">
                <p class="os-kicker">Progress</p>
                <strong class="lab-progress-number" data-lab-number data-lab-target={item.progress} data-lab-suffix="%">0%</strong>
                <span class="lab-progress lab-progress--large" aria-label={`${item.progress}% planning progress`}>
                  <span></span>
                </span>
              </div>
            </section>

            <section class="project-dossier-section lab-dossier-section">
              <p class="os-kicker">The Problem</p>
              <p>{item.problem}</p>
            </section>

            <section class="project-dossier-section lab-dossier-section">
              <p class="os-kicker">Vision</p>
              <p>{item.vision}</p>
            </section>

            <section class="project-dossier-section lab-dossier-section">
              <p class="os-kicker">Competitor Landscape</p>
              <p>A compact market scan confirms this is an active space with fragmented solutions.</p>
              <div class="lab-competitors" aria-label="Competitors researched">
                {item.competitors.map((competitor) => <span>{competitor}</span>)}
              </div>
            </section>

            <section class="project-dossier-section lab-dossier-section">
              <p class="os-kicker">Roadmap</p>
              <ol class="lab-roadmap" aria-label={`${item.title} roadmap`}>
                {item.roadmap.map((step) => (
                  <li class:list={[step === item.stage && 'is-active']}>
                    <span>{step}</span>
                  </li>
                ))}
              </ol>
            </section>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="os-panel os-panel--skills" data-section-panel="skills" data-os-panel="skills">
    <h1 class="os-title">SKILLS</h1>
    <svg class="os-connectors os-connectors--skills" viewBox="0 0 760 460" preserveAspectRatio="none" aria-hidden="true">
      <path pathLength="1" d="M378 86 V128 H278" />
      <path pathLength="1" d="M390 88 V150 H500" />
      <path pathLength="1" d="M290 270 H220 V330" />
      <path pathLength="1" d="M472 262 H552 V328" />

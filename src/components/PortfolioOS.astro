    status: 'Live business',
    cover: '/assets/washywashyThumbnail.avif',
    hero: '/assets/washywashyThumbnail.avif',
    tech: ['SvelteKit', 'PocketBase', 'TypeScript', 'PWA', 'Admin Dashboard'],
    oneLine: 'Doorstep car washing with customer booking, washer operations, and real launch traction.',

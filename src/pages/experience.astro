---
import BaseLayout from '@layouts/BaseLayout.astro';

const roles = [
  {
    period: '2024 - Present',
    title: 'Founder & Product Engineer',
    company: 'WashyWashy',
    summary: 'Built and launched a production doorstep service platform from scratch, combining engineering, product strategy, operations, marketing, and AI automation into a functioning business serving real customers.'
  },
  {
    period: '2021 - 2022',
    title: 'Software Engineering Intern',
    company: 'Inflection Zone Dev Labs',
    summary: 'Worked on production software, repository maintenance, feature implementation, bug fixes, Git workflows, and collaborative development.'
  },
  {
    period: '2020 - 2024',
    title: 'Freelance Software Developer',
    company: 'International Clients',
    summary: 'Worked with international clients delivering web development, technical consulting, SEO, digital strategy, and performance optimization.'
  },
  {
    period: 'Ended June 2026',
    title: 'Product & Growth Contributor',
    company: 'griv.io',
    summary: 'Worked within an early-stage startup environment across product and growth initiatives until the engagement ended in June 2026.'
  }
];
---

<BaseLayout title="Experience" description="Professional experience and career timeline.">
  <section class="page-section">
    <p class="eyebrow">Experience</p>
    <h1>Experience</h1>
    <p class="lead">
      A clean timeline keeps the page easy to scan while leaving room for specific wins.
    </p>
  </section>

  <section class="band">
    <div class="page-section timeline">
      {
        roles.map((role) => (
          <article class="timeline-item">
            <time>{role.period}</time>
            <div>
              <h3>{role.title} · {role.company}</h3>
              <p>{role.summary}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

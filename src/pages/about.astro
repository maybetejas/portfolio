---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About page for the portfolio owner.">
  <section class="page-section">
    <p class="eyebrow">About</p>
    <h1>A concise story about the person behind the work.</h1>
    <p class="lead">
      Use this page to explain your background, taste, working style, and the problems you
      like solving. Keep it human, specific, and easy to skim.
    </p>
  </section>

  <section class="band">
    <div class="page-section grid two">
      <article class="card">
        <h3>What I do</h3>
        <p>
          Describe the kind of projects you build, the stacks you enjoy, and the business
          outcomes you care about.
        </p>
      </article>
      <article class="card">
        <h3>How I work</h3>
        <p>
          Highlight collaboration style, communication, product thinking, and how you move
          from idea to shipped work.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

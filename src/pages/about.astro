---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About page for the portfolio owner.">
  <section class="page-section">
    <p class="eyebrow">About</p>
    <h1>Tejas Khandale</h1>
    <p class="lead">
      I build web products, AI systems, and automation designed around how people actually work.
    </p>
  </section>

  <section class="band">
    <div class="page-section grid two">
      <article class="card">
        <h3>Biography</h3>
        <p>
          I am a full-stack developer based in Pune, working at the intersection of software
          engineering, product thinking, and interface design.
        </p>
      </article>
      <article class="card">
        <h3>Operating Style</h3>
        <p>
          I start from user workflows, prototype rapidly, prioritize clarity, and build systems
          that scale while remaining maintainable.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

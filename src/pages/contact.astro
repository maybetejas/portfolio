---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact information and links.">
  <section class="page-section">
    <p class="eyebrow">Contact</p>
    <h1>Open a transmission.</h1>
    <p class="lead">
      Email, phone, and platform links for project work, collaboration, and technical conversations.
    </p>
  </section>

  <section class="band">
    <div class="page-section">
      <div class="contact-panel">
        <div>
          <h2>Email works best.</h2>
          <p class="lead">tejasatwork100@gmail.com</p>
        </div>
        <a class="button" href="mailto:tejasatwork100@gmail.com">Send Email</a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact information and links.">
  <section class="page-section">
    <p class="eyebrow">Contact</p>
    <h1>Make the next conversation easy.</h1>
    <p class="lead">
      Add your preferred email, social links, and a short note about what kinds of messages
      are welcome.
    </p>
  </section>

  <section class="band">
    <div class="page-section">
      <div class="contact-panel">
        <div>
          <h2>Email works best.</h2>
          <p class="lead">your.email@example.com</p>
        </div>
        <a class="button" href="mailto:your.email@example.com">Send Email</a>
      </div>
    </div>
  </section>
</BaseLayout>
